    "signature_hash": "d105b2add2781541cb9c12540477cc5fe7e3fb4d1271f1ea9cf8ccc2e17de9fd",
    "url": "https://docs.python.org/3/library/logging.html#module-logging#logging.lastResort",
    "parameters": [],
    "return_type": "",
    "exceptions": [],
    "description": {
      "es": "",
      "en": "A “handler of last resort” is available through this attribute. This is a StreamHandler writing to sys.stderr with a level of WARNING, and is used to handle logging events in the absence of any logging configuration. The end result is to just print the message to sys.stderr. This replaces the earlier error message saying that “no handlers could be found for logger XYZ”. If you need the earlier behaviour for some reason, lastResort can be set to None. Added in version 3.2."
    },
    "example": "",
    "articles": [],
