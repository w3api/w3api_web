  "doctest/REPORT_ONLY_FIRST_FAILURE": {
    "id": "doctest.REPORT_ONLY_FIRST_FAILURE",
    "name": "REPORT_ONLY_FIRST_FAILURE",
    "type": "constant",
    "parent": null,
