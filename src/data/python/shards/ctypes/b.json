    ],
    "signature_hash": "b255670b36930a7e32f9c394e01702a491a4911ff9095896475f5868d07f5e9e",
    "url": "https://docs.python.org/3/library/ctypes.html#module-ctypes#ctypes.byref",
    "parameters": [
      {
        "name": "obj[, offset",
        "type": "",
        "has_default": false,
        "default_value": null,
        "is_keyword_only": false,
        "is_var_args": false,
        "is_var_kwargs": false,
        "description": {
          "es": "",
          "en": ""
        }
      }
    ],
    "return_type": "",
    "exceptions": [],
    "description": {
      "es": "",
      "en": "Returns a light-weight pointer to obj, which must be an instance of a ctypes type. offset defaults to zero, and must be an integer that will be added to the internal pointer value. byref(obj, offset) corresponds to this C code: (((char *)&obj) + offset) The returned object can only be used as a foreign function call parameter. It behaves similar to pointer(obj), but the construction is a lot faster."
    },
