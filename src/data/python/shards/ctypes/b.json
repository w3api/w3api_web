    "url": "https://docs.python.org/3/library/ctypes.html#module-ctypes#ctypes.CField.bit_offset",
    "parameters": [],
    "return_type": "",
    "exceptions": [],
    "description": {
      "es": "",
      "en": "The location of a bitfield within its storage unit, that is, within byte_size bytes of memory starting at byte_offset. To get the field’s value, read the storage unit as an integer, shift left by bit_offset and take the bit_size least significant bits. For non-bitfields, bit_offset is zero and bit_size is equal to byte_size * 8."
    },
    "example": "",
