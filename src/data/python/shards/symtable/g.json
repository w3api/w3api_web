    "url": "https://docs.python.org/3/library/symtable.html#module-symtable#symtable.SymbolTable.get_name",
    "parameters": [],
    "return_type": "",
    "exceptions": [],
    "description": {
      "es": "",
      "en": "Return the table’s name. This is the name of the class if the table is for a class, the name of the function if the table is for a function, or 'top' if the table is global (get_type() returns 'module'). For type parameter scopes (which are used for generic classes, functions, and type aliases), it is the name of the underlying class, function, or type alias. For type alias scopes, it is the name of the type alias. For TypeVar bound scopes, it is the name of the TypeVar."
    },
