    "parameters": [],
    "return_type": "",
    "exceptions": [],
    "description": {
      "es": "",
      "en": "The child’s exit code. This will be None if the process has not yet terminated. If the child’s run() method returned normally, the exit code will be 0. If it terminated via sys.exit() with an integer argument N, the exit code will be N. If the child terminated due to an exception not caught within run(), the exit code will be 1. If it was terminated by signal N, the exit code will be the negative value -N."
    },
    "example": "",
