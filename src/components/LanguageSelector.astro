---
interface Props {
  currentLanguage?: string;
}

const { currentLanguage = 'java' } = Astro.props;

const languages = [
  { id: 'java', name: 'Java', href: '/java/' },
  { id: 'python', name: 'Python', href: '/python/' },
  { id: 'xml', name: 'XML', href: '/xml/' },  
];
---

<div class="language-selector">
  <label for="lang-select" class="lang-label">Tecnología</label>
  <select id="lang-select" class="lang-select">
    {languages.map((lang) => (
      <option value={lang.id} data-href={lang.href} selected={lang.id === currentLanguage}>
        {lang.name}
      </option>
    ))}
  </select>
</div>

<style>
  .language-selector {
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .lang-label {
    font-size: var(--sl-text-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sl-color-gray-5);
  }

  .lang-select {
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--sl-color-hairline-shade);
    border-radius: 0.375rem;
    background-color: var(--sl-color-bg-sidebar);
    color: var(--sl-color-text);
    font-size: 0.875rem;
    cursor: pointer;
    transition: border-color 0.2s;
  }

  .lang-select:hover {
    border-color: var(--sl-color-accent);
  }

  .lang-select:focus {
    outline: none;
    border-color: var(--sl-color-accent);
    box-shadow: 0 0 0 2px var(--sl-color-accent-low);
  }
</style>

<script>
  const select = document.getElementById('lang-select') as HTMLSelectElement;
  
  if (select) {
    select.addEventListener('change', (e) => {
      const target = e.target as HTMLSelectElement;
      const option = target.selectedOptions[0];
      const href = option.getAttribute('data-href');
      
      if (href) {
        window.location.href = href;
      }
    });
  }
</script>
