---
import { t, type Language } from '../i18n';

interface Props {
  currentLanguage?: string;
  languageCode?: Language;
  hasLanguagePrefix?: boolean;
}

const { currentLanguage = 'java', languageCode = 'es', hasLanguagePrefix = true } = Astro.props;

const languages = [
  { id: 'css', name: 'CSS', icon: 'devicon-css3-plain' },
  { id: 'html', name: 'HTML', icon: 'devicon-html5-plain' },
  { id: 'java', name: 'Java', icon: 'devicon-java-plain' },
  { id: 'javascript', name: 'JavaScript', icon: 'devicon-javascript-plain' },
  { id: 'jquery', name: 'jQuery', icon: 'devicon-jquery-plain' },
  { id: 'python', name: 'Python', icon: 'devicon-python-plain' },
  { id: 'svg', name: 'SVG', icon: 'devicon-html5-plain colored"' },
  { id: 'xml', name: 'XML', icon: 'devicon-xml-plain' },
].map((lang) => ({
  ...lang,
  href: hasLanguagePrefix ? `/${languageCode}/${lang.id}/` : `/${lang.id}/`,
}));

const currentLang = languages.find((lang) => lang.id === currentLanguage);
---

<div class="language-selector">
  <label class="lang-label">{t('technology', languageCode)}</label>
  <div class="lang-dropdown">
    <button class="lang-button" id="lang-button">
      {currentLang && (
        <>
          <i class={`devicon ${currentLang.icon}`}></i>
          <span>{currentLang.name}</span>
        </>
      )}
      <svg class="dropdown-chevron" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </button>
    
    <div class="lang-menu" id="lang-menu">
      {languages.map((lang) => (
        <a href={lang.href} class={`lang-menu-item ${lang.id === currentLanguage ? 'active' : ''}`} data-lang-id={lang.id}>
          <i class={`devicon ${lang.icon}`}></i>
          <span>{lang.name}</span>
          {lang.id === currentLanguage && (
            <svg class="checkmark" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          )}
        </a>
      ))}
    </div>
  </div>
</div>

<style>
  .language-selector {
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .lang-label {
    font-size: var(--sl-text-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sl-color-gray-5);
  }

  .lang-dropdown {
    position: relative;
  }

  .lang-button {
    width: 100%;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--sl-color-hairline-shade);
    border-radius: 0.375rem;
    background-color: var(--sl-color-bg-sidebar);
    color: var(--sl-color-text);
    font-size: 0.875rem;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    justify-content: space-between;
  }

  .lang-button:hover {
    border-color: var(--sl-color-accent);
  }

  .lang-button:focus {
    outline: none;
    border-color: var(--sl-color-accent);
    box-shadow: 0 0 0 2px var(--sl-color-accent-low);
  }

  .lang-button i {
    font-size: 1rem;
    width: 1.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lang-button span {
    flex: 1;
    text-align: left;
  }

  .dropdown-chevron {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    transition: transform 0.2s;
  }

  .lang-button[data-open="true"] .dropdown-chevron {
    transform: rotate(180deg);
  }

  .lang-menu {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    margin-top: 0.25rem;
    background-color: var(--sl-color-bg-sidebar);
    border: 1px solid var(--sl-color-hairline-shade);
    border-radius: 0.375rem;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    z-index: 100;
    display: none;
    flex-direction: column;
    overflow: hidden;
  }

  .lang-menu[data-open="true"] {
    display: flex;
  }

  .lang-menu-item {
    padding: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--sl-color-text);
    text-decoration: none;
    transition: all 0.15s;
    cursor: pointer;
    border-left: 3px solid transparent;
  }

  .lang-menu-item:hover {
    background-color: var(--sl-color-accent-low);
    border-left-color: var(--sl-color-accent);
  }

  .lang-menu-item.active {
    background-color: var(--sl-color-accent-low);
    border-left-color: var(--sl-color-accent);
    font-weight: 600;
  }

  .lang-menu-item i {
    font-size: 1.25rem;
    width: 1.5rem;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lang-menu-item span {
    flex: 1;
  }

  .checkmark {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    color: var(--sl-color-accent);
  }
</style>

<script>
  const button = document.getElementById('lang-button') as HTMLButtonElement;
  const menu = document.getElementById('lang-menu') as HTMLElement;
  const menuItems = document.querySelectorAll('.lang-menu-item') as NodeListOf<HTMLAnchorElement>;

  let isOpen = false;

  // Toggle dropdown
  button?.addEventListener('click', () => {
    isOpen = !isOpen;
    button.setAttribute('data-open', isOpen.toString());
    menu?.setAttribute('data-open', isOpen.toString());
  });

  // Close dropdown when clicking outside
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (!button?.contains(target) && !menu?.contains(target)) {
      isOpen = false;
      button?.setAttribute('data-open', 'false');
      menu?.setAttribute('data-open', 'false');
    }
  });

  // Close dropdown when clicking on a menu item
  menuItems.forEach((item) => {
    item.addEventListener('click', () => {
      isOpen = false;
      button?.setAttribute('data-open', 'false');
      menu?.setAttribute('data-open', 'false');
    });
  });

  // Handle keyboard navigation
  button?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      isOpen = !isOpen;
      button.setAttribute('data-open', isOpen.toString());
      menu?.setAttribute('data-open', isOpen.toString());
      if (isOpen) {
        menuItems[0]?.focus();
      }
    }
  });

  menuItems.forEach((item, index) => {
    item.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        (menuItems[index + 1] || menuItems[0])?.focus();
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        (menuItems[index - 1] || menuItems[menuItems.length - 1])?.focus();
      } else if (e.key === 'Escape') {
        e.preventDefault();
        isOpen = false;
        button?.setAttribute('data-open', 'false');
        menu?.setAttribute('data-open', 'false');
        button?.focus();
      }
    });
  });
</script>
