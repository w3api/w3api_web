---
import LanguageSelector from './LanguageSelector.astro';
import { t } from '../i18n';
import type { Language } from '../i18n';

interface SidebarItem {
  label: string;
  link?: string;
  items?: SidebarItem[];
  badge?: { text: string; variant?: 'default' | 'note' | 'tip' | 'caution' | 'danger' | 'success' };
  collapsed?: boolean;
}

interface Props {
  items: SidebarItem[];
  currentPath: string;
  languageCode?: Language;
  currentTechnology?: string;
  hasLanguagePrefix?: boolean;
  hasSidebar: boolean;
  technologyFilter?: string;
}

const { items, currentPath, languageCode = 'en', currentTechnology = 'java', hasLanguagePrefix = true, hasSidebar, technologyFilter } = Astro.props;

const buildUrl = (link: string) => {
  if (hasLanguagePrefix) {
    return `/${languageCode}/${link}`;
  }
  return `/${link}`;
};
---

{hasSidebar && (
  <nav id="sidebar" class="sl-sidebar" aria-label="Navegación principal">          
    <div class="sl-sidebar-inner">
      <LanguageSelector currentLanguage={currentTechnology} languageCode={languageCode} hasLanguagePrefix={hasLanguagePrefix} />
      <div class="sl-search-filter">
        {technologyFilter && <label class="sl-search-label">{t(technologyFilter, languageCode)}</label>}
        <input 
          id="sidebar-search" 
          type="text" 
          placeholder="Filtrar..." 
          class="sl-search-input"
          aria-label="Filtrar navegación"
        />
      </div>
      {items.map((group) => {
        // Detectar si algún item dentro del grupo está activo
        // Normalizar currentPath: quitar idioma si existe
        const pathSegments = currentPath.split('/').filter(Boolean);
        let normalizedPath = pathSegments;
        // Si el primer segmento es idioma, quitarlo
        if (hasLanguagePrefix && (pathSegments[0] === 'en' || pathSegments[0] === 'es')) {
          normalizedPath = pathSegments.slice(1);
        }
        const normalizedPathStr = normalizedPath.join('/') + '/';
        
        const hasActiveItem = group.items?.some((item) => {
          // Comparar exacto o si el currentPath es un descendiente del item
          return item.link === normalizedPathStr || normalizedPathStr.startsWith(item.link);
        });
        
        return (
        <div class="sl-sidebar-group">
          {group.items ? (
            <>
              <details open={hasActiveItem || !group.collapsed} class="sl-sidebar-details">
                <summary class="sl-sidebar-group-label">
                  <svg class="sl-chevron" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="9 18 15 12 9 6"/>
                  </svg>
                  {group.label}
                </summary>
                <ul class="sl-sidebar-list">
                  {group.items.map((item) => {
                    // Normalizar currentPath: quitar idioma si existe
                    const pathSegments = currentPath.split('/').filter(Boolean);
                    let normalizedSegments = pathSegments;
                    if (hasLanguagePrefix && (pathSegments[0] === 'en' || pathSegments[0] === 'es')) {
                      normalizedSegments = pathSegments.slice(1);
                    }
                    const normalizedPathStr = normalizedSegments.join('/') + '/';
                    // Marcar como activo si coincide exacto o si normalizedPath es descendiente del item
                    const isActive = item.link === normalizedPathStr || normalizedPathStr.startsWith(item.link);
                    return (
                    <li>
                      <a
                        href={buildUrl(item.link)}
                        class:list={['sl-sidebar-link', { 'sl-active': isActive }]}
                        aria-current={isActive ? 'page' : undefined}
                      >
                        {item.label}
                        {item.badge && (
                          <span class={`sl-badge sl-badge-${item.badge.variant ?? 'default'}`}>
                            {item.badge.text}
                          </span>
                        )}
                      </a>
                    </li>
                    );
                  })}
                </ul>
              </details>
            </>
          ) : (
            <a
              href={buildUrl(group.link)}
              class:list={['sl-sidebar-link sl-sidebar-link-top', { 'sl-active': (() => {
                const pathSegments = currentPath.split('/').filter(Boolean);
                let normalizedSegments = pathSegments;
                if (hasLanguagePrefix && (pathSegments[0] === 'en' || pathSegments[0] === 'es')) {
                  normalizedSegments = pathSegments.slice(1);
                }
                const normalizedPathStr = normalizedSegments.join('/') + '/';
                return group.link === normalizedPathStr || normalizedPathStr.startsWith(group.link);
              })() }]}
              aria-current={(() => {
                const pathSegments = currentPath.split('/').filter(Boolean);
                let normalizedSegments = pathSegments;
                if (hasLanguagePrefix && (pathSegments[0] === 'en' || pathSegments[0] === 'es')) {
                  normalizedSegments = pathSegments.slice(1);
                }
                const normalizedPathStr = normalizedSegments.join('/') + '/';
                return group.link === normalizedPathStr || normalizedPathStr.startsWith(group.link) ? 'page' : undefined;
              })()}
            >
              {group.label}
            </a>
          )}
        </div>
        );
      })}
      
      <!-- Navigation Links (Mobile only) -->
      <div class="sl-sidebar-nav-mobile">
        <h3 class="sl-sidebar-section-title">{t('nav_label', languageCode)}</h3>
        <ul class="sl-sidebar-mobile-links">
          <li><a href={buildUrl('apis/')}>{t('nav_apis', languageCode)}</a></li>
          <li><a href={buildUrl('lista-correo/')}>{t('nav_mailing_list', languageCode)}</a></li>
          <li><a href={buildUrl('blog/')}>{t('nav_blog', languageCode)}</a></li>
        </ul>
      </div>

      <!-- Social Icons (Tablet and Mobile) -->
      <div class="sl-sidebar-social-mobile">
        <h3 class="sl-sidebar-section-title">{t('social_networks', languageCode)}</h3>
        <div class="sl-sidebar-social-links">
          <a href="https://www.facebook.com/W3Api/" class="sl-sidebar-social-link" aria-label="Facebook" target="_blank" rel="noopener noreferrer">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href="https://x.com/w3api" class="sl-sidebar-social-link" aria-label="X (Twitter)" target="_blank" rel="noopener noreferrer">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.657l-5.207-6.807-5.966 6.807H2.882l7.432-8.499L1.085 2.25h6.82l4.713 6.231 5.579-6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <a href="https://github.com/w3api" class="sl-sidebar-social-link" aria-label="GitHub" target="_blank" rel="noopener noreferrer">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
          <a href="https://www.linkedin.com/in/victorcuervo/" class="sl-sidebar-social-link" aria-label="LinkedIn" target="_blank" rel="noopener noreferrer">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.475-2.236-1.986-2.236-1.081 0-1.722.722-2.004 1.418-.103.249-.129.597-.129.946v5.441h-3.554s.05-8.824 0-9.745h3.554v1.378c.429-.662 1.196-1.608 2.905-1.608 2.324 0 4.068 1.516 4.068 4.78v5.195zM5.337 8.855c-1.144 0-1.915-.758-1.915-1.71 0-.956.77-1.71 1.954-1.71 1.184 0 1.915.754 1.915 1.71 0 .952-.731 1.71-1.954 1.71zm1.649 11.597H3.694V9.407h3.292v10.845zM22.224 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.224 0z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </nav>
)}

<style>
  /* ============================
     SIDEBAR
     ============================ */
  .sl-sidebar {
    position: fixed;
    top: var(--sl-header-height);
    bottom: 0;
    inset-inline-start: 0;
    width: var(--sl-sidebar-width);
    overflow-y: auto;
    background-color: var(--sl-color-bg-sidebar);
    border-inline-end: 1px solid var(--sl-color-hairline);
    z-index: 8;
    transform: translateX(-100%);
    transition: transform 0.25s ease;
    scrollbar-width: thin;
    scrollbar-color: var(--sl-color-gray-3) transparent;
  }

  .sl-sidebar[data-open="true"] {
    transform: translateX(0);
  }

  @media (min-width: 50rem) {
    .sl-sidebar {
      transform: translateX(0);
    }
  }

  .sl-sidebar-inner {
    padding: 1rem 0 2rem;
  }

  /* Search Filter */
  .sl-search-filter {
    padding: 0.75rem 1rem;
  }

  .sl-search-label {
    display: block;
    font-size: var(--sl-text-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sl-color-gray-5);
    margin-bottom: 0.5rem;
  }

  .sl-search-input {
    width: 100%;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--sl-color-hairline-shade);
    border-radius: var(--sl-border-radius);
    background-color: var(--sl-color-bg-sidebar);
    color: var(--sl-color-text);
    font-size: var(--sl-text-sm);
    font-family: var(--sl-font);
    box-sizing: border-box;
    transition: border-color 0.2s;
  }

  .sl-search-input:focus {
    outline: none;
    border-color: var(--sl-color-accent);
    box-shadow: 0 0 0 2px var(--sl-color-accent-low);
  }

  .sl-search-input::placeholder {
    color: var(--sl-color-gray-4);
  }

  /* Groups */
  .sl-sidebar-group {
    margin-bottom: 0.25rem;
  }

  .sl-sidebar-details {
    border: none;
    padding: 0;
    margin: 0;
  }

  .sl-sidebar-group-label {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.375rem 1rem;
    font-size: var(--sl-text-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sl-color-gray-4);
    cursor: pointer;
    list-style: none;
    user-select: none;
  }
  .sl-sidebar-group-label::-webkit-details-marker { display: none; }
  .sl-sidebar-group-label::marker { display: none; }
  .sl-sidebar-group-label:hover { color: var(--sl-color-text); }

  .sl-chevron {
    flex-shrink: 0;
    transition: transform 0.2s;
  }
  .sl-sidebar-details[open] .sl-chevron {
    transform: rotate(90deg);
  }

  /* Links */
  .sl-sidebar-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .sl-sidebar-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.3rem 1rem 0.3rem 1.75rem;
    font-size: var(--sl-text-sm);
    color: var(--sl-color-text);
    border-inline-start: 2px solid transparent;
    transition: color 0.15s, background 0.15s, border-color 0.15s;
    text-decoration: none;
  }
  .sl-sidebar-link:hover {
    color: var(--sl-color-accent-high);
    background: var(--sl-color-bg-accent);
    border-inline-start-color: var(--sl-color-accent);
  }
  .sl-sidebar-link.sl-active {
    color: var(--sl-color-accent-high);
    background: var(--sl-color-bg-accent);
    border-inline-start-color: var(--sl-color-accent);
    font-weight: 600;
  }

  .sl-sidebar-link-top {
    padding-inline-start: 1rem;
    font-weight: 600;
  }

  /* Badges */
  .sl-badge {
    font-size: 0.6rem;
    font-weight: 700;
    padding: 0.1em 0.45em;
    border-radius: 9999px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }
  .sl-badge-default  { background: var(--sl-color-bg-badge-default); color: var(--sl-color-text-badge-default); }
  .sl-badge-note     { background: #dbeafe; color: #1e40af; }
  .sl-badge-tip      { background: #dcfce7; color: #166534; }
  .sl-badge-caution  { background: #fef9c3; color: #854d0e; }
  .sl-badge-danger   { background: #fee2e2; color: #991b1b; }
  .sl-badge-success  { background: #dcfce7; color: #166534; }

  [data-theme="dark"] .sl-badge-note    { background: #1e3a5f; color: #93c5fd; }
  [data-theme="dark"] .sl-badge-tip     { background: #14532d; color: #86efac; }
  [data-theme="dark"] .sl-badge-caution { background: #451a03; color: #fcd34d; }
  [data-theme="dark"] .sl-badge-danger  { background: #450a0a; color: #fca5a5; }
  [data-theme="dark"] .sl-badge-success { background: #14532d; color: #86efac; }

  /* Mobile Navigation and Social Icons */
  .sl-sidebar-nav-mobile,
  .sl-sidebar-social-mobile {
    display: none;
  }

  @media (max-width: 768px) {
    .sl-sidebar-nav-mobile,
    .sl-sidebar-social-mobile {
      display: block;
    }
  }

  .sl-sidebar-section-title {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sl-color-gray-4);
    padding: 1rem 1rem 0.5rem 1rem;
    margin: 1rem 0 0 0;
  }

  .sl-sidebar-mobile-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .sl-sidebar-mobile-links li {
    padding: 0;
  }

  .sl-sidebar-mobile-links a {
    display: block;
    padding: 0.5rem 1rem;
    color: var(--sl-color-text);
    text-decoration: none;
    font-size: var(--sl-text-sm);
    border-left: 3px solid transparent;
    transition: all 0.15s ease;
  }

  .sl-sidebar-mobile-links a:hover {
    background: var(--sl-color-bg-accent);
    color: var(--sl-color-accent);
    border-left-color: var(--sl-color-accent);
  }

  .sl-sidebar-social-links {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0 1rem 1rem 1rem;
    flex-wrap: wrap;
  }

  .sl-sidebar-social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    color: var(--sl-color-text);
    transition: color 0.15s, transform 0.15s;
    border-radius: var(--sl-border-radius);
  }

  .sl-sidebar-social-link:hover {
    color: var(--sl-color-accent);
    transform: scale(1.15);
  }

  .sl-sidebar-social-link svg {
    width: 100%;
    height: 100%;
  }

</style>

<script>
  // Auto-scroll al elemento activo cuando se carga la página
  document.addEventListener('DOMContentLoaded', () => {
    const sidebar = document.getElementById('sidebar');
    const activeLink = sidebar?.querySelector('.sl-sidebar-link.sl-active');
    
    if (activeLink && sidebar) {
      // Esperar un poco para que el layout se estabilice
      setTimeout(() => {
        const linkPosition = (activeLink as HTMLElement).offsetTop;
        const sidebarHeight = sidebar.clientHeight;
        const scrollTop = sidebar.scrollTop;
        
        // Scroll con margen para que no quede en el borde
        const targetScroll = linkPosition - sidebarHeight / 2 + 40;
        sidebar.scrollTop = Math.max(0, targetScroll);
      }, 100);
    }
  });

  const searchInput = document.getElementById('sidebar-search') as HTMLInputElement;
  const sidebarGroups = document.querySelectorAll('.sl-sidebar-group');
  const detailsElements = document.querySelectorAll('.sl-sidebar-details');

  if (searchInput) {
    searchInput.addEventListener('input', (e) => {
      const query = (e.target as HTMLInputElement).value.toLowerCase();

      sidebarGroups.forEach((group) => {
        const details = group.querySelector('.sl-sidebar-details');
        const links = group.querySelectorAll('.sl-sidebar-link');
        let hasMatches = false;

        links.forEach((link) => {
          const text = link.textContent?.toLowerCase() || '';
          const matches = query === '' || text.includes(query);
          (link.parentElement as HTMLElement).style.display = matches ? '' : 'none';
          if (matches) hasMatches = true;
        });

        if (details) {
          // Mostrar/ocultar el grupo
          (group as HTMLElement).style.display = hasMatches || query === '' ? '' : 'none';
          
          // Abrir automáticamente si hay coincidencias
          if (query !== '' && hasMatches) {
            (details as HTMLDetailsElement).open = true;
          } else if (query === '') {
            (details as HTMLDetailsElement).open = !(details as any).__originalCollapsed;
          }
        }
      });
    });

    // Guardar estado original collapsed
    detailsElements.forEach((details) => {
      (details as any).__originalCollapsed = !(details as HTMLDetailsElement).open;
    });
  }
</script>
