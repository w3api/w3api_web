---
/**
 * Search.astro
 * Componente de búsqueda modal con Algolia
 * - Input en desktop, lupa en móvil
 * - Se abre con clic o Ctrl+F / Cmd+F
 * - Resultados en modal
 */
import { t } from '../i18n';
import type { Language } from '../i18n';

interface Props {
  uiLanguage?: Language;
}

const { uiLanguage = 'en' } = Astro.props;

const appId = import.meta.env.PUBLIC_ALGOLIA_APP_ID;
const apiKey = import.meta.env.PUBLIC_ALGOLIA_SEARCH_KEY;
const indexName = import.meta.env.PUBLIC_ALGOLIA_INDEX_NAME;

const placeholderText = t('search_title', uiLanguage).charAt(0).toUpperCase() + t('search_title', uiLanguage).slice(1);
---

<!-- Devicon CSS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/devicons/devicon@v2.16.0/devicon.min.css"></link>

<!-- Search Trigger Button (Desktop) -->
<button
  id="search-trigger"
  class="sl-search-trigger"
  aria-label="Search"
  title="Search (Ctrl+K)"
>
  <div class="sl-search-button-left">
    <svg class="sl-search-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
    </svg>
    <span class="sl-search-label">{t('search_title', uiLanguage).charAt(0).toUpperCase() + t('search_title', uiLanguage).slice(1)}</span>
  </div>
  <span class="sl-search-hint" id="search-shortcut">Ctrl K</span>
</button>

<!-- Search Modal -->
<div id="search-modal" class="sl-search-modal" role="dialog" aria-hidden="true">
  <div class="sl-search-modal-overlay"></div>
  <div class="sl-search-modal-content">
    <div class="sl-search-modal-header">
      <input
        id="search-input"
        type="text"
        class="sl-search-modal-input"
        placeholder={placeholderText}
        aria-label={placeholderText}
      />
      <button
        id="search-close"
        class="sl-search-modal-close"
        aria-label="Close search"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <div class="sl-search-modal-results" id="search-results"></div>
  </div>
</div>

<style>
  /* Search Trigger Button */
  .sl-search-trigger {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    padding: 0.5rem 0;
    padding-left: 0.5rem;
    padding-right: 1rem;
    background: var(--sl-color-bg-sidebar);
    border: 1px solid var(--sl-color-hairline);
    border-radius: var(--sl-border-radius);
    color: var(--sl-color-text);
    cursor: pointer;
    font-size: var(--sl-text-sm);
    transition: background 0.15s, border-color 0.15s;
    flex: 1;
    max-width: 600px;
  }

  @media (max-width: 50rem) {
    .sl-search-trigger {
      padding: 0 0.5rem;
      background: transparent;
      border: none;
      color: #000;
      flex: 1;
      max-width: none;
      justify-content: flex-end;
      padding-right: 1rem;
    }

    .sl-search-trigger:hover {
      background: transparent;
      border-color: transparent;
    }

    .sl-search-button-left {
      gap: 0;
    }
  }

  @media (max-width: 450px) {
    .sl-search-trigger {
      padding: 0 0.25rem;
    }
  }

  .sl-search-button-left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .sl-search-icon {
    width: 20px;
    height: 20px;
    display: inline-block;
    flex-shrink: 0;
    color: var(--sl-color-text);
  }

  @media (max-width: 50rem) {
    .sl-search-icon {
      width: 24px;
      height: 24px;
    }
  }

  @media (max-width: 600px) {
    .sl-search-icon {
      width: 20px;
      height: 20px;
    }
  }

  @media (max-width: 450px) {
    .sl-search-icon {
      width: 18px;
      height: 18px;
    }
  }

  .sl-search-label {
    font-size: var(--sl-text-sm);
    font-weight: 500;
    color: var(--sl-color-text);
  }

  @media (max-width: 50rem) {
    .sl-search-label {
      display: none;
    }

    .sl-search-button-left {
      gap: 0;
      flex: none;
    }
  }

  .sl-search-trigger:hover {
    background: var(--sl-color-bg-accent);
    border-color: var(--sl-color-accent);
  }

  .sl-search-hint {
    font-size: 0.75rem;
    color: #000;
    display: none;
    margin-left: auto;
    padding-right: 0.5rem;
    background: #e0e0e0;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
  }

  @media (min-width: 50rem) {
    .sl-search-hint {
      display: inline;
    }
  }

  /* Search Modal */
  .sl-search-modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: none;
    align-items: flex-start;
    justify-content: center;
    padding-top: 5rem;
  }

  .sl-search-modal[data-open="true"] {
    display: flex;
  }

  .sl-search-modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    opacity: 0;
    transition: opacity 0.2s;
    pointer-events: none;
  }

  .sl-search-modal[data-open="true"] .sl-search-modal-overlay {
    opacity: 1;
    pointer-events: auto;
  }

  .sl-search-modal-content {
    position: relative;
    width: calc(100% - 2rem);
    max-width: 600px;
    background: var(--sl-color-bg);
    border-radius: var(--sl-border-radius);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.15),
                0 10px 20px rgba(0, 0, 0, 0.1);
    max-height: 80vh;
    display: flex;
    flex-direction: column;
    border: 1px solid var(--sl-color-hairline);
    padding: 1rem;
  }

  @media (max-width: 50rem) {
    .sl-search-modal-content {
      width: calc(100% - 1rem);
      max-width: 100%;
    }
  }

  .sl-search-modal-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem;
    border-bottom: 1px solid var(--sl-color-hairline);
    background: var(--sl-color-bg-sidebar);
    border-top-left-radius: var(--sl-border-radius);
    border-top-right-radius: var(--sl-border-radius);
  }

  .sl-search-modal-input {
    flex: 1;
    background: transparent;
    border: 2px solid #0066cc;
    padding: 0.5rem;
    font-size: var(--sl-text-lg);
    color: var(--sl-color-text);
    font-family: inherit;
    outline: none;
    font-weight: 500;
    border-radius: 6px;
  }

  .sl-search-modal-input::placeholder {
    color: var(--sl-color-gray-4);
  }

  .sl-search-modal-input:focus {
    color: var(--sl-color-text);
    border-color: #0052a3;
  }

  .sl-search-modal-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    background: transparent;
    border: none;
    color: var(--sl-color-gray-4);
    cursor: pointer;
    border-radius: var(--sl-border-radius);
    transition: all 0.2s ease;
    flex-shrink: 0;
  }

  .sl-search-modal-close:hover {
    background: var(--sl-color-bg);
    color: var(--sl-color-text);
    transform: rotate(90deg);
  }

  .sl-search-modal-results {
    overflow-y: auto;
    padding: 12px 12px;
    flex: 1;
  }

  .sl-search-modal-results::-webkit-scrollbar {
    width: 6px;
  }

  .sl-search-modal-results::-webkit-scrollbar-track {
    background: transparent;
  }

  .sl-search-modal-results::-webkit-scrollbar-thumb {
    background: var(--sl-color-hairline);
    border-radius: 3px;
  }

  .sl-search-modal-results::-webkit-scrollbar-thumb:hover {
    background: var(--sl-color-gray-3);
  }

  .search-result {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    border-radius: 10px;
    transition: background 0.2s ease;
    cursor: pointer;
  }

  .search-result + .search-result {
    margin-top: 8px;
  }

  .search-result:hover {
    background: #f5f7fa;
  }

  .icon {
    width: 40px;
    height: 40px;
    border-radius: 8px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    color: white;
    font-size: 20px;
  }

  .icon.java {
    background: linear-gradient(135deg, #f89820, #ed8b00);
  }

  .icon.javascript {
    background: linear-gradient(135deg, #f7df1e, #f1c40f);
    color: #1a1a1a;
  }

  .icon.python {
    background: linear-gradient(135deg, #3776ab, #ffd43b);
    color: white;
  }

  .icon.css {
    background: linear-gradient(135deg, #264bdd, #563d7c);
  }

  .icon.html {
    background: linear-gradient(135deg, #e34c26, #ff6b6b);
  }

  .icon.xml {
    background: linear-gradient(135deg, #f57c00, #ff9100);
  }

  .icon.svg {
    background: linear-gradient(135deg, #ffb13b, #ffa500);
    color: #1a1a1a;
  }

  .icon.jquery {
    background: linear-gradient(135deg, #0868ac, #1e90ff);
  }

  .icon.webapi {
    background: linear-gradient(135deg, #4285f4, #34a853);
    color: white;
  }

  .content {
    display: flex;
    flex-direction: column;
  }

  .title {
    font-size: 16px;
    font-weight: 600;
    color: #1a1a1a;
    line-height: 1.2;
    text-decoration: none;
    cursor: pointer;
    transition: color 0.2s ease;
  }

  .title:hover {
    color: var(--sl-color-accent);
  }

  .subtitle {
    font-size: 13px;
    color: #6b7280;
    margin-top: 2px;
    text-decoration: none;
    font-weight: 500;
  }

  .sl-search-no-results {
    padding: 3rem 1rem;
    text-align: center;
    color: var(--sl-color-gray-4);
    font-size: var(--sl-text-sm);
    font-weight: 500;
  }

  /* Mobile: Hide text, show only icon */
  @media (max-width: 49.999rem) {
    .sl-search-hint {
      display: none;
    }
  }

  [data-theme="dark"] .sl-search-trigger {
    background: var(--sl-color-bg-sidebar);
    border-color: var(--sl-color-hairline);
  }

  [data-theme="dark"] .sl-search-trigger:hover {
    background: var(--sl-color-bg-accent);
  }
</style>

<script define:vars={{ appId, apiKey, indexName }}>
  // Search Modal Management
  const modal = document.getElementById('search-modal');
  const trigger = document.getElementById('search-trigger');
  const closeBtn = document.getElementById('search-close');
  const input = document.getElementById('search-input');
  const resultsContainer = document.getElementById('search-results');
  const overlay = document.querySelector('.sl-search-modal-overlay');

  let searchClient;
  let searchIndex;

  // Initialize Algolia
  async function initAlgolia() {
    if (!appId || !apiKey || !indexName) {
      console.warn('Algolia not configured');
      return;
    }

    try {
      const { algoliasearch } = window;
      if (!algoliasearch) {
        // Load Algolia dynamically if not loaded
        await new Promise((resolve) => {
          const script = document.createElement('script');
          script.src = 'https://cdn.jsdelivr.net/npm/algoliasearch@4/dist/algoliasearch-lite.umd.js';
          script.onload = resolve;
          document.head.appendChild(script);
        });
      }

      searchClient = window.algoliasearch(appId, apiKey);
      searchIndex = searchClient.initIndex(indexName);
    } catch (e) {
      console.error('Algolia initialization failed:', e);
    }
  }

  // Open modal
  function openModal() {
    modal.setAttribute('data-open', 'true');
    modal.setAttribute('aria-hidden', 'false');
    input.focus();
    document.body.style.overflow = 'hidden';
  }

  // Close modal
  function closeModal() {
    modal.removeAttribute('data-open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    input.value = '';
    resultsContainer.innerHTML = '';
  }

  // Search
  async function search(query) {
    if (!searchIndex) {
      console.warn('Search index not initialized. appId:', appId, 'indexName:', indexName);
      resultsContainer.innerHTML = '<div class="sl-search-no-results">Search not available</div>';
      return;
    }

    if (!query.trim()) {
      resultsContainer.innerHTML = '';
      return;
    }

    try {
      console.log('Searching for:', query);
      const response = await searchIndex.search(query);
      const hits = response.hits || response;
      
      console.log('Search results:', hits.length, hits);

      if (hits.length === 0) {
        resultsContainer.innerHTML = '<div class="sl-search-no-results">No results found</div>';
        return;
      }

      // Estilos inline por tecnología
      const gradients = {
        java: '#e0e0e0',
        javascript: '#e0e0e0',
        python: '#e0e0e0',
        css: '#e0e0e0',
        html: '#e0e0e0',
        xml: '#e0e0e0',
        svg: '#e0e0e0',
        jquery: '#e0e0e0',
        webapi: '#e0e0e0'
      };

      const devicons = {
        java: 'devicon-java-plain',
        javascript: 'devicon-javascript-plain',
        python: 'devicon-python-plain',
        css: 'devicon-css3-plain',
        html: 'devicon-html5-plain',
        xml: 'devicon-xml-plain',
        svg: 'devicon-svg-plain',
        jquery: 'devicon-jquery-plain',
        webapi: 'devicon-chrome-plain'
      };

      resultsContainer.innerHTML = hits
        .map(
          (hit) => {
            const elemento = hit.elemento || hit.title || hit.name || 'Untitled';
            const paquete = hit.paquete || hit.module || hit.package || '';
            const lenguaje = hit.lenguaje || hit.language || hit.lang || 'en';
            const slug = hit.slug || hit.objectID || '';
            const href = `/${lenguaje}/${slug}/`;
            
            const bgColor = '#e0e0e0';
            const devicon = devicons[lenguaje] || 'devicon-file-plain';
            
            return `
        <div style="display: flex; align-items: center; gap: 12px; padding: 12px 16px; border-radius: 10px; transition: background 0.2s ease; cursor: pointer; margin-bottom: 8px;" onmouseover="this.style.background='#f5f7fa'" onmouseout="this.style.background=''">
          <div style="width: 40px; height: 40px; border-radius: 8px; background: ${bgColor}; display: flex; align-items: center; justify-content: center; color: #333; font-weight: bold; font-size: 24px; flex-shrink: 0;">
            <i class="${devicon}" style="color: #333;"></i>
          </div>
          <div style="display: flex; flex-direction: column; cursor: pointer;">
            <a href="${href}" style="font-size: 16px; font-weight: 600; color: #1a1a1a; line-height: 1.2; text-decoration: none; transition: color 0.2s ease;" onmouseover="this.style.color='#0066cc'" onmouseout="this.style.color='#1a1a1a'">
              ${elemento}
            </a>
            <div style="font-size: 13px; color: #6b7280; margin-top: 2px; font-weight: 500;">
              ${paquete}
            </div>
          </div>
        </div>
      `;
          }
        )
        .join('');
    } catch (e) {
      console.error('Search error:', e);
      resultsContainer.innerHTML = '<div class="sl-search-no-results">Search error: ' + e.message + '</div>';
    }
  }

  // Event Listeners
  trigger?.addEventListener('click', openModal);
  closeBtn?.addEventListener('click', closeModal);
  overlay?.addEventListener('click', closeModal);

  // Ctrl+K or Cmd+K
  document.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
      e.preventDefault();
      openModal();
    } else if (e.key === 'Escape') {
      closeModal();
    }
  });

  // Search input listener
  input?.addEventListener('input', (e) => {
    search(e.target.value);
  });

  // Initialize on page load
  window.addEventListener('load', () => {
    initAlgolia();
  });

  // Try immediate initialization
  initAlgolia().catch(() => {});

  // Detect OS and update shortcut text
  const isMac = /Mac|iPhone|iPad|iPod/.test(navigator.platform);
  const shortcutElement = document.getElementById('search-shortcut');
  if (shortcutElement) {
    if (isMac) {
      shortcutElement.textContent = '⌘ K';
    } else {
      shortcutElement.textContent = 'Ctrl K';
    }
  }
</script>
