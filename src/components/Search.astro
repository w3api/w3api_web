---
/**
 * Search.astro
 * Componente de búsqueda para el header
 */
---

<button class="sl-search-btn" aria-label="Buscar">
  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="11" cy="11" r="8"/>
    <line x1="21" y1="21" x2="16.65" y2="16.65"/>
  </svg>
  <span class="sl-search-label">Buscar</span>
  <kbd class="sl-search-kbd"><kbd>Ctrl</kbd><kbd>K</kbd></kbd>
</button>

<style>
  .sl-search-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background-color: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-hairline);
    border-radius: var(--sl-border-radius);
    color: var(--sl-color-text);
    font-size: 0.875rem;
    cursor: pointer;
    transition: background-color 0.15s, border-color 0.15s;
  }

  .sl-search-btn:hover {
    background-color: var(--sl-color-accent-low);
    border-color: var(--sl-color-accent);
  }

  .sl-search-label {
    display: none;
  }

  .sl-search-kbd {
    display: flex;
    gap: 0.25rem;
    margin-left: 0.5rem;
  }

  .sl-search-kbd kbd {
    padding: 0.15rem 0.35rem;
    background-color: var(--sl-color-bg);
    border: 1px solid var(--sl-color-hairline-shade);
    border-radius: 0.25rem;
    font-size: 0.75rem;
    font-family: monospace;
    color: var(--sl-color-gray-5);
  }

  @media (min-width: 50rem) {
    .sl-search-label {
      display: inline;
    }
  }
</style>

<script>
  const searchBtn = document.querySelector('.sl-search-btn');
  
  if (searchBtn) {
    searchBtn.addEventListener('click', () => {
      console.log('Search clicked');
      // Aquí puedes agregar lógica de búsqueda
    });

    // Atajo de teclado Ctrl+K
    document.addEventListener('keydown', (e) => {
      if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
        e.preventDefault();
        searchBtn.focus();
        console.log('Search shortcut triggered');
      }
    });
  }
</script>
