import StarlightLayout from '../layouts/StarlightLayout.astro';
import { sidebar } from '../config/sidebar.ts';


// Table of contents — ideally auto-generated from headings
const tableOfContents = [
  { depth: 2, text: '¿Qué es Astro?', slug: 'que-es-astro' },
  { depth: 2, text: 'Instalación rápida', slug: 'instalacion-rapida' },
  { depth: 3, text: 'Requisitos', slug: 'requisitos' },
  { depth: 3, text: 'Crear un proyecto', slug: 'crear-proyecto' },
