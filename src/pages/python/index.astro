---
import StarlightLayout from '../../layouts/StarlightLayout.astro';
import { sidebar } from '../../config/sidebars/python_sidebar';
import rutas from '../../data/python/routes.json'

// Importar todos los archivos de distribución de shards
const distributionModules = import.meta.glob('../../data/python/modules/*.json', { eager: true })

// Procesar módulos para obtener información de paquetes
const packages: any[] = []

Object.entries(distributionModules).forEach(([key, module]: any) => {
  const data = module.default || module
  
  // Procesar cada paquete en el archivo de distribución
  if (Array.isArray(data)) {
    data.forEach((item: any) => {
      if (item.slug && item.shard) {
        const packageName = item.slug.split('/')[0]
        
        // Buscar si ya existe este paquete
        let pkg = packages.find(p => p.name === packageName)
        
        if (!pkg) {
          pkg = {
            name: packageName,
            slug: packageName,
            totalElements: 0,
            classes: 0,
            functions: 0,
            methods: 0,
            constants: 0,
            exceptions: 0,
            shard: item.shard
          }
          packages.push(pkg)
        }
        
        pkg.totalElements++
      }
    })
  }
})

// Ordenar alfabéticamente
packages.sort((a, b) => a.name.localeCompare(b.name))

// Obtener detalles de cada paquete desde su módulo
const shardModules = import.meta.glob('../../data/python/shards/**/*.json', { eager: true })

packages.forEach((pkg: any) => {
  const shardPath = `../../data/${pkg.shard}`
  const shardModule = shardModules[shardPath] as any
  
  if (shardModule) {
    const shard = shardModule.default || shardModule
    const packageDoc = shard[pkg.name]
    
    if (packageDoc) {
      if (packageDoc.classes) pkg.classes = packageDoc.classes.length
      if (packageDoc.functions) pkg.functions = packageDoc.functions.length
      if (packageDoc.methods) pkg.methods = packageDoc.methods.length
      if (packageDoc.constants) pkg.constants = packageDoc.constants.length
      if (packageDoc.exceptions) pkg.exceptions = packageDoc.exceptions.length
      
      // Contar métodos de todas las clases del módulo
      if (packageDoc.classes && Array.isArray(packageDoc.classes)) {
        let methodCount = 0
        packageDoc.classes.forEach((className: string) => {
          // Buscar métodos que pertenecen a esta clase
          const methodPattern = `${pkg.name}/${className}/`
          Object.keys(shard).forEach((key: string) => {
            if (key.startsWith(methodPattern) && shard[key].type === 'method') {
              methodCount++
            }
          })
        })
        if (methodCount > 0) {
          pkg.methods = methodCount
        }
      }
    }
  }
})

const headings = [
  { level: 2, title: 'Modules', id: 'packages' }
]

const tableOfContents = headings.map(h => ({
  depth: h.level,
  text: h.title,
  slug: h.id
}))
---

<StarlightLayout
  title="Python"
  description="Listado completo de módulos Python disponibles"
  siteTitle="W3Api"
  sidebar={sidebar}
  tableOfContents={tableOfContents}
  currentLanguage="python"  
  logoSrc='/logo.webp'
  filterLabel="Módulos"
>

<main>
  <article>
    <header class="sl-content-header">
      <h1>Python</h1>
    </header>

    <hr class="header-divider" />

    <section id="packages">
      <h2>Modules</h2>
      
      <div class="packages-table-container">
        <table class="packages-table">
          <thead>
            <tr>
              <th>Module Name</th>
              <th class="text-right">Classes</th>
              <th class="text-right">Funciones</th>
              <th class="text-right">Métodos</th>
              <th class="text-right">Constantes</th>
              <th class="text-right">Excepciones</th>
              <th class="text-right">Total</th>
            </tr>
          </thead>
          <tbody>
            {packages.map((pkg: any) => (
              <tr>
                <td>
                  <a href={`/python/${pkg.slug}/`} class="package-link">
                    {pkg.name}
                  </a>
                </td>
                <td class="text-right">{pkg.classes || 0}</td>
                <td class="text-right">{pkg.functions || 0}</td>
                <td class="text-right">{pkg.methods || 0}</td>
                <td class="text-right">{pkg.constants || 0}</td>
                <td class="text-right">{pkg.exceptions || 0}</td>
                <td class="text-right total">{pkg.totalElements}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="packages-summary">
        <p>Total de módulos: <strong>{packages.length}</strong></p>
        <p>Total de elementos: <strong>{packages.reduce((sum: number, pkg: any) => sum + pkg.totalElements, 0)}</strong></p>
      </div>
    </section>
  </article>
</main>

<style>
  .header-divider {
    border: none;
    border-top: 1px solid #e8e8e8;
    margin: 1rem 0;
  }

  .sl-content-header h1 {
    margin: 0;
  }

  .packages-table-container {
    overflow-x: auto;
    margin: 2rem 0;
    border: 1px solid var(--sl-color-hairline);
    border-radius: var(--sl-border-radius);
  }

  .packages-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }

  .packages-table thead {
    background-color: var(--sl-color-bg-nav);
    border-bottom: 2px solid var(--sl-color-hairline);
  }

  .packages-table th {
    padding: 1rem;
    text-align: left;
    font-weight: 600;
    color: var(--sl-color-text);
    border-right: 1px solid var(--sl-color-hairline);
  }

  .packages-table th:last-child {
    border-right: none;
  }

  .packages-table td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--sl-color-hairline);
    border-right: 1px solid var(--sl-color-hairline);
  }

  .packages-table td:last-child {
    border-right: none;
  }

  .packages-table tbody tr:hover {
    background-color: var(--sl-color-accent-low);
  }

  .package-link {
    color: var(--sl-color-accent);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.15s;
  }

  .package-link:hover {
    color: var(--sl-color-accent-high);
    text-decoration: underline;
  }

  .text-right {
    text-align: right;
  }

  .total {
    font-weight: 600;
    color: var(--sl-color-accent);
  }

  .packages-summary {
    background-color: var(--sl-color-accent-low);
    padding: 1rem;
    border-radius: var(--sl-border-radius);
    margin-top: 2rem;
  }

  .packages-summary p {
    margin: 0.5rem 0;
    color: var(--sl-color-text);
  }

  .packages-summary strong {
    color: var(--sl-color-accent);
  }
</style>

</StarlightLayout>
