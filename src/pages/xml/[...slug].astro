---
import DocumentLayout from '../../layouts/DocumentLayout.astro';
import rutas from '../../data/xml/routes.json';
import { loadDocument, loadPackage, generateTableOfContents } from '../../utils/loadDocumentation';
import { LANGUAGES } from '../../config/languages';

const LANGUAGE_KEY = 'xml';

const sidebarModules = import.meta.glob('../../config/sidebars/*_sidebar.ts', { eager: true });
const distributionModules = import.meta.glob('../../data/xml/modules/*.json', { eager: true });
const shardModules = import.meta.glob('../../data/xml/shards/**/*.json', { eager: true });

export async function getStaticPaths() {
  return (rutas || []).map((slug: string) => ({
    params: { slug },
    props: LANGUAGES['xml'],
  }));
}

interface Props {
  language: string;
  languageName: string;
  codeLanguage: string;
  filterLabel: string;
}

const { language, languageName, codeLanguage, filterLabel } = Astro.props;
const slug = Astro.params.slug as string;
const sidebarModule = sidebarModules[`../../config/sidebars/${language}_sidebar.ts`] as any;
const sidebar = sidebarModule?.default || sidebarModule?.sidebar || [];

const packageName = slug.split('/')[0];
const moduleKey = `../../data/${language}/modules/${packageName}.json`;
const distributionModule = distributionModules[moduleKey] as any;
const distributionFile = distributionModule.default || distributionModule;

const isPackageOnly = slug === packageName;
let doc: any;

if (isPackageOnly) {
  doc = loadPackage(packageName, distributionFile, shardModules, language);
} else {
  doc = loadDocument(slug, distributionFile, shardModules, packageName, language);
}

const tableOfContents = generateTableOfContents(doc, isPackageOnly);
---

<DocumentLayout
  {doc}
  {slug}
  {sidebar}
  {language}
  {languageName}
  currentLanguage={language}
  {filterLabel}
  {codeLanguage}
  isPackagePage={isPackageOnly}
  {tableOfContents}
/>
