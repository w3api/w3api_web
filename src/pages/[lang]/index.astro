---
/**
 * src/pages/[lang]/index.astro
 * Página Home con soporte multiidioma (en, es)
 * Rutas: /en/ y /es/
 */
import StarlightLayout from '../../layouts/StarlightLayout.astro';
import { t, getTranslations } from '../../i18n';
import type { Language } from '../../i18n';

export async function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'es' } },
  ];
}

const lang = (Astro.params.lang || 'es') as Language;
const translations = getTranslations(lang);
---

<StarlightLayout
  title={`${translations.tagline || 'Unified API Reference'} - W3Api`}
  description={translations.quoteMain || 'Unified API Reference. All languages and frameworks. One standard.'}
  siteTitle="W3Api"
  logoSrc='/logo.webp'
  hasSidebar={false}
  hasToc={false}
  uiLanguage={lang}
>

<main>
    <article>
      <section class="hero">
        <div class="hero-content">
          <h1>Unified API Reference</h1>
          <p class="tagline">{t('tagline', lang)}</p>
          
          <div class="hero-actions">
            <a href={`/${lang === 'es' ? 'es/' : 'en/'}java/`} class="btn btn-primary">{t('exploreDocumentation', lang)}</a>
            <a href={`/${lang === 'es' ? 'es/' : 'en/'}blog`} class="btn btn-secondary">{t('viewApis', lang)}</a>
          </div>
        </div>
        
        <img src="/logo.webp" alt="W3Api" class="hero-logo" />
      </section>

        <div class="demo-section">        
            <blockquote class="bq-quote">
                <p>{t('quoteMain', lang)}</p>
                <cite>— W3Api</cite>
            </blockquote>
        </div>

    </article>
  </main>

<style>
  :global(.sl-content-panel.sl-no-sidebar) {
    margin: 0 auto !important;
    max-width: min(95vw, 1400px);
  }

  :global(.sl-content) {
    width: 100%;
    max-width: none;
  }

  :global(.sl-main) {
    width: 100%;
  }

  main {
    width: 100%;
    max-width: none;
  }

  article {
    width: 100%;
  }

  /* Hero Section */
  .hero {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 3rem;
    margin: 0;
  }

  .hero-logo {
    width: 400px;
    height: 400px;
    object-fit: contain;
    flex-shrink: 0;
  }

  .hero-content {
    flex: 1;
    min-width: 280px;
  }

  .hero-content h1 {
    margin: 0 0 1rem 0;
    font-size: clamp(1.8rem, 7vw, 3rem);
    font-weight: 700;
    line-height: 1.2;
  }

  .tagline {
    font-size: 1.1rem;
    font-weight: 350;
    line-height: 1.8;    
    margin: 0 0 2rem 0;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.5rem;
    border-radius: var(--sl-border-radius);
    font-weight: 600;
    text-decoration: none;
    border: 2px solid;
    transition: all 0.2s ease;
  }

  .btn-primary {
    background-color: var(--sl-color-accent);
    color: var(--sl-color-white);
    border-color: var(--sl-color-accent);
  }

  .btn-primary:hover {
    background-color: var(--sl-color-accent-high);
    border-color: var(--sl-color-accent-high);
    transform: translateY(-2px);
  }

  .btn-secondary {
    background-color: transparent;
    color: var(--sl-color-accent);
    border-color: var(--sl-color-accent);
  }

  .btn-secondary:hover {
    background-color: var(--sl-color-accent-low);
    border-color: var(--sl-color-accent-high);
    color: var(--sl-color-accent-high);
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .hero {
      flex-direction: column-reverse;
      text-align: center;
      gap: 0rem;
    }

    .hero-logo {
      width: 250px;
      height: 250px;
    }

    .hero-actions {
      justify-content: center;
    }
  }

    .bq-quote {
        position: relative;
        padding: 40px 36px 36px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 2px;
    }
    .bq-quote::before {
        content: '\201C';
        font-family: 'Playfair Display', serif;
        font-size: 9rem;
        line-height: 1;
        color: var(--sl-color-accent-teal);
        opacity: 0.8;
        position: absolute;
        top: -20px;
        left: 20px;
        pointer-events: none;
    }
    .bq-quote p {
        font-size: clamp(1rem, 2.2vw, 1.25rem);
        line-height: 1.7;
        font-weight: 300;
        position: relative;
        z-index: 1;
    }
    .bq-quote cite {
        display: block;
        margin-top: 20px;
        font-size: 0.75rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--sl-color-accent-teal);
        font-style: normal;
    }

</style>

</StarlightLayout>
