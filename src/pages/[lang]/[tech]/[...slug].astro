---
import DocumentLayout from '../../../layouts/DocumentLayout.astro';
import { buildMembersByType, generateTableOfContents } from '../../../utils/loadDocumentation';
import { LANGUAGES } from '../../../config/languages';
import { getPluralName } from '../../../config/elementTypes';
import type { Language } from '../../../i18n';

export async function getStaticPaths() {
  const UI_LANGUAGES: Language[] = ['en', 'es'];
  const TECHS = ['css', 'html', 'java', 'javascript', 'jquery', 'python', 'svg', 'xml'];
  
  const routes: any[] = [];
  
  for (const tech of TECHS) {
    try {
      const rutasModule = await import(`../../../data/${tech}/routes.json`);
      const rutas = rutasModule.default || rutasModule;
      
      for (const slug of rutas || []) {
        for (const lang of UI_LANGUAGES) {
          routes.push({
            params: { lang, tech, slug },
            props: LANGUAGES[tech as keyof typeof LANGUAGES],
          });
        }
      }
    } catch (e) {
      console.warn(`No routes found for ${tech}`);
    }
  }
  
  return routes;
}

interface Props {
  technology: string;
  technologyName: string;
  technologyCode: string;
  technologyFilter: string;
}

const { technology, technologyName, technologyCode, technologyFilter } = Astro.props;
const { lang, tech, slug } = Astro.params;
const uiLanguage: Language = lang as Language;

// Importar sidebars
const sidebarsModules = import.meta.glob<any>('../../../config/sidebars/*_sidebar.ts', { eager: true });
const sidebarKey = Object.keys(sidebarsModules).find((key) =>
  key.includes(`/${technology}_sidebar.ts`)
);
const sidebarModule = sidebarKey ? sidebarsModules[sidebarKey] : null;
const sidebar = sidebarModule?.default || sidebarModule?.sidebar || [];

// Importar módulos y shards
const modulesPattern = import.meta.glob<any>('../../../data/*/modules/*.json', { eager: true });
const shardsGlob = import.meta.glob<any>('../../../data/*/shards/**/*.json', { eager: true });

const packageName = slug!.split('/')[0];

// Filtrar módulos para este tech
const distributionModules = Object.entries(modulesPattern || {})
  .filter(([path]) => path.includes(`/data/${tech}/modules/`))
  .map(([_, module]) => module.default || module);

// Buscar el array que contiene este packageName
const distributionFile = distributionModules.find((data: any) => {
  if (Array.isArray(data)) {
    return data.some((item: any) => item.slug === packageName);
  }
  return false;
}) || [];

// Encontrar la ruta metadata
const routeMeta = distributionFile.find((r: any) => r.slug === slug);

if (!routeMeta) {
  throw new Error(`Route not found: ${slug} in ${tech}`);
}

// Cargar shard - TODOS los archivos del módulo
const shardKeys = Object.keys(shardsGlob || {}).filter((key) =>
  (key.includes(routeMeta.shard) || key.includes(`shards/${packageName}/`)) && 
  key.includes(`/data/${tech}/shards/`)
);

const shard: Record<string, any> = {};
shardKeys.forEach(key => {
  const shardModule = shardsGlob[key];
  const shardData = shardModule ? (shardModule.default || shardModule) : {};
  Object.assign(shard, shardData);
});

const isPackageOnly = slug === packageName;
let doc = shard[slug] || shard[packageName] || {};

// Si es solo un módulo/paquete, siempre buscar en el shard para agregar elementos
if (isPackageOnly) {
  // Buscar TODOS los elementos en el shard que pertenecen a este paquete
  const allElements: Record<string, any[]> = {};
  const searchPrefix = `${packageName}/`;
  
  Object.entries(shard).forEach(([shardKey, value]: [string, any]) => {
    // Incluir cualquier clave que empiece con "packageName/"
    // Y filtrar: solo elementos de primer nivel (sin parent)
    if (shardKey.startsWith(searchPrefix) && !value.parent) {
      const type = value.type || 'other';
      if (!allElements[type]) allElements[type] = [];
      
      // Agregar la propiedad slug desde la clave del shard
      const element = {
        ...value,
        slug: shardKey, // Usar la clave como slug
      };
      allElements[type].push(element);
    }
  });

  // Si encontramos elementos, actualizar doc
  if (Object.keys(allElements).length > 0) {
    // Construir membersByType directamente
    const membersByType: Record<string, any[]> = {};
    
    Object.entries(allElements).forEach(([type, items]) => {
      membersByType[type] = items;
      
      // Obtener nombre plural correcto desde la configuración
      const propName = getPluralName(technology, type);
      
      // Asignar a doc
      doc[propName as any] = items;
    });
    
    doc.membersByType = membersByType;
  }
}

// Asegurar que doc tiene la estructura necesaria
const finalMembersByType = isPackageOnly && doc.membersByType && Object.keys(doc.membersByType).length > 0 
  ? doc.membersByType 
  : buildMembersByType(doc, packageName, technology as any);

doc = {
  name: doc.name || slug,
  type: doc.type || (isPackageOnly ? 'Package' : 'Document'),
  description: doc.description || `${isPackageOnly ? 'Package' : 'Document'}: ${slug}`,
  membersByType: finalMembersByType,
  signatures: Array.isArray(doc.signatures) ? doc.signatures : [],
  parameters: Array.isArray(doc.parameters) ? doc.parameters : [],
  constructors: Array.isArray(doc.constructors) ? doc.constructors : [],
  methods: Array.isArray(doc.methods) ? doc.methods : [],
  attributes: Array.isArray(doc.attributes) ? doc.attributes : [],
  exceptions: Array.isArray(doc.exceptions) ? doc.exceptions : [],
  classes: Array.isArray(doc.classes) ? doc.classes : [],
  interfaces: Array.isArray(doc.interfaces) ? doc.interfaces : [],
  enums: Array.isArray(doc.enums) ? doc.enums : [],
  annotations: Array.isArray(doc.annotations) ? doc.annotations : [],
  functions: Array.isArray(doc.functions) ? doc.functions : [],
  constants: Array.isArray(doc.constants) ? doc.constants : [],
  elements: Array.isArray(doc.elements) ? doc.elements : [],
  ...doc,
};

const tableOfContents = generateTableOfContents(doc, isPackageOnly);
---

<DocumentLayout
  {doc}
  {slug}
  {sidebar}
  technology={technology}
  technologyName={technologyName}
  uiLanguage={uiLanguage}
  technologyCode={technologyCode}
  technologyFilter={technologyFilter}
  isPackagePage={isPackageOnly}
  {tableOfContents}
/>
