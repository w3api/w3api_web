---
import StarlightLayout from '../../layouts/StarlightLayout.astro';
import { t, type Language } from '../../i18n';
import { LANGUAGES } from '../../config/languages';

export async function getStaticPaths() {
  const TECHS = ['css', 'html', 'java', 'javascript', 'jquery', 'python', 'svg', 'xml'];
  
  return TECHS.map((tech) => ({
    params: { tech },
    props: LANGUAGES[tech as keyof typeof LANGUAGES],
  }));
}

interface Props {
  technology: string;
  technologyName: string;
  technologyCode: string;
  technologyFilter: string;
}

const { technology, technologyName, technologyCode, technologyFilter } = Astro.props;
const uiLanguage: Language = 'en';

// Importar sidebar
const sidebarsModules = import.meta.glob('../../config/sidebars/*_sidebar.ts', { eager: true });
const sidebarKey = `../../config/sidebars/${technology}_sidebar.ts`;
const sidebarModule = sidebarsModules[sidebarKey] as any;
const sidebar = sidebarModule?.default || sidebarModule?.sidebar || [];

// Importar módulos de distribución
const distributionModules = import.meta.glob<any>('../../data/*/modules/*.json', { eager: true });
const moduleKeys = Array.from(Object.keys(distributionModules)).filter((key) =>
  key.includes(`/data/${technology}/modules/`)
);
const distributionFile = moduleKeys.flatMap((key) => {
  const data = distributionModules[key].default || distributionModules[key];
  return Array.isArray(data) ? data : [data];
});

// Importar shards
const shardModules = import.meta.glob('../../data/*/shards/**/*.json', { eager: true });

// Procesar módulos para obtener información de paquetes/módulos
const packages: any[] = [];

console.log('Technology:', technology);
console.log('Module Keys found:', moduleKeys.length);
console.log('Distribution File:', Array.isArray(distributionFile) ? `Array with ${distributionFile.length} items` : distributionFile);

// Determinar si esta tecnología tiene estructura de paquetes o solo módulos
const hasPackageStructure = ['java', 'jquery', 'python'].includes(technology);

if (Array.isArray(distributionFile)) {
  distributionFile.forEach((item: any) => {
    // Determinar si este es un paquete (tiene /) o un módulo (no tiene /)
    const hasPkg = item.slug && item.slug.includes('/');
    const packageName = hasPkg ? item.slug.split('/')[0] : item.slug;
    
    let pkg = packages.find((p) => p.name === packageName);
    
    if (!pkg) {
      pkg = {
        name: packageName,
        slug: packageName,
        totalElements: 0,
        classes: 0,
        interfaces: 0,
        exceptions: 0,
        enums: 0,
        annotations: 0,
        shard: item.shard,
      };
      packages.push(pkg);
    }
    
    pkg.totalElements++;
  });
}

console.log('Packages processed:', packages.length, packages.map(p => p.name));

packages.sort((a, b) => a.name.localeCompare(b.name));

packages.forEach((pkg: any) => {
  const shardPath = `../../data/${pkg.shard}`;
  const shardModule = Object.entries(shardModules || {}).find(([key]) => key === shardPath)?.[1] as any;
  
  if (shardModule) {
    const shard = shardModule.default || shardModule;
    const packageDoc = shard[pkg.name];
    
    if (packageDoc) {
      if (packageDoc.classes) pkg.classes = packageDoc.classes.length;
      if (packageDoc.interfaces) pkg.interfaces = packageDoc.interfaces.length;
      if (packageDoc.exceptions) pkg.exceptions = packageDoc.exceptions.length;
      if (packageDoc.enums) pkg.enums = packageDoc.enums.length;
      if (packageDoc.annotations) pkg.annotations = packageDoc.annotations.length;
    }
  }
});

const headings = [{ level: 2, title: t(technologyFilter, uiLanguage), id: 'packages' }];

const tableOfContents = headings.map((h) => ({
  depth: h.level,
  text: h.title,
  slug: h.id,
}));
---

<StarlightLayout
  title={technologyName}
  description={`Listado completo de paquetes ${technologyName} disponibles`}
  siteTitle="W3Api"
  sidebar={sidebar}
  tableOfContents={tableOfContents}
  uiLanguage={uiLanguage}
  logoSrc='/logo.webp'
  technologyFilter={technologyFilter}
>
  <main>
    <article>
      <header class="sl-content-header">
        <h1>{technologyName}</h1>
      </header>

      <hr class="header-divider" />

      <section id="packages">
        <h2>{t(technologyFilter, uiLanguage)}</h2>

        <div class="packages-table-container">
          <table class="packages-table">
            <thead>
              <tr>
                <th>{t(technologyFilter, uiLanguage)}</th>
              </tr>
            </thead>
            <tbody>
              {packages.map((pkg: any) => (
                <tr>
                  <td>
                    <a href={`/${technology}/${pkg.slug}/`} class="package-link">
                      {pkg.name}
                    </a>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    </article>
  </main>
</StarlightLayout>

<style>
  .packages-table-container {
    overflow-x: auto;
    margin: 2rem 0;
  }

  .packages-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.95rem;
  }

  .packages-table th {
    background-color: var(--sl-color-bg-hover);
    padding: 0.75rem;
    text-align: left;
    font-weight: 600;
    border-bottom: 2px solid var(--sl-color-hairline);
  }

  .packages-table td {
    padding: 0.75rem;
    border-bottom: 1px solid var(--sl-color-hairline);
  }

  .packages-table tr:hover {
    background-color: var(--sl-color-bg-hover);
  }

  .package-link {
    color: var(--sl-color-accent);
    text-decoration: none;
    transition: color 0.15s;
  }

  .package-link:hover {
    color: var(--sl-color-accent-high);
    text-decoration: underline;
  }

  .text-right {
    text-align: right;
  }

  .text-right.total {
    font-weight: 600;
  }
</style>
