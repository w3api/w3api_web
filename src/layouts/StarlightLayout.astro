---
import SidebarNav from '../components/SidebarNav.astro';
import Search from '../components/Search.astro';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import { SEO } from 'astro-seo';
import { t } from '../i18n';
import type { Language } from '../i18n';

/**
 * StarlightLayout.astro
 * Un Layout para Astro inspirado en el diseño de Starlight.
 * 
 * Props:
 * - title: string (requerido) — título de la página
 * - description?: string — meta descripción
 * - sidebar?: Array<{ label: string; items?: SidebarItem[]; link?: string }> — navegación lateral
 * - tableOfContents?: Array<{ depth: number; text: string; slug: string }> — índice de la página
 * - hasSidebar?: boolean — mostrar/ocultar sidebar (default: true)
 * - hasToc?: boolean — mostrar/ocultar tabla de contenidos (default: true)
 * - siteTitle?: string — nombre del sitio
 * - logoSrc?: string — ruta al logo
 * - currentLanguage?: string — lenguaje actual (default: 'java')
 * - filterLabel?: string — etiqueta para el filtro del sidebar (ej: "Paquetes")
 */

interface SidebarItem {
  label: string;
  link?: string;
  items?: SidebarItem[];
  badge?: { text: string; variant?: 'default' | 'note' | 'tip' | 'caution' | 'danger' | 'success' };
  collapsed?: boolean;
}

interface TocItem {
  depth: number;
  text: string;
  slug: string;
}

interface Props {
  title: string;
  description?: string;
  sidebar?: SidebarItem[];
  tableOfContents?: TocItem[];
  hasSidebar?: boolean;
  hasToc?: boolean;
  siteTitle?: string;
  logoSrc?: string;
  uiLanguage?: Language;
  technologyFilter?: string;
}

const {
  title,
  description = '',
  sidebar = [],
  tableOfContents = [],
  hasSidebar = true,
  hasToc = true,
  siteTitle = 'W3Api',
  logoSrc,
  uiLanguage = 'en',
  technologyFilter,
} = Astro.props;

const currentPath = Astro.url.pathname;

// Determinar si el path tiene idioma: /en/java/... o /es/java/... vs /java/...
const pathSegments = currentPath.split('/').filter(Boolean);
const hasLanguagePrefix = pathSegments[0] === 'en' || pathSegments[0] === 'es';
const currentTechnology = hasLanguagePrefix ? (pathSegments[1] || 'java') : (pathSegments[0] || 'java');
---

<!doctype html>
<html lang={uiLanguage} dir="ltr">
  <head>
    <SEO
      title={title}
      description={description}
      openGraph={{
        basic: {
          title: title,
          type: 'website',
          image: '/banner.webp',
          url: Astro.url.href,
        },
        optional: {
          description: description,
          siteName: siteTitle,
        },
        image: {
          alt: 'All languages and frameworks. One standard.',
        },
      }}
      twitter={{
        creator: '@w3api',
        image: '/banner.webp',
        imageAlt: 'All languages and frameworks. One standard.',
      }}
    />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {description && <meta name="description" content={description} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@500;600;700&display=swap" rel="stylesheet">
  </head>

  <body>
    <!-- HEADER -->
    <header class="sl-header">
      <div class="sl-header-inner">
        <div class="sl-header-start">
          <!-- Mobile menu toggle -->
          <button
            id="mobile-menu-toggle"
            class="sl-mobile-toggle"
            aria-label="Abrir menú de navegación"
            aria-expanded="false"
            aria-controls="sidebar"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="3" y1="6" x2="21" y2="6"/>
              <line x1="3" y1="12" x2="21" y2="12"/>
              <line x1="3" y1="18" x2="21" y2="18"/>
            </svg>
          </button>

          <!-- Logo / Site Title -->
          <a href={hasLanguagePrefix ? `/${uiLanguage}/` : "/"} class="sl-site-title">
            {logoSrc && <img src={logoSrc} alt={siteTitle} class="sl-logo" />}
            <span>{siteTitle}</span>
          </a>
        </div>

        <!-- SEARCH CENTER -->
        <div class="sl-header-center">
          <Search uiLanguage={uiLanguage} />
        </div>

        <!-- NAVIGATION LINKS -->
        <nav class="sl-header-nav">
          <a href="/apis" class="sl-nav-link">APIs</a>
          <a href="/lista-correo" class="sl-nav-link">Lista de Correo</a>
          <a href="/blog" class="sl-nav-link">Blog</a>
        </nav>

        <!-- SOCIAL ICONS -->
        <div class="sl-header-social">
          <a href="https://www.facebook.com/W3Api/" class="sl-social-link" aria-label="Facebook" target="_blank" rel="noopener noreferrer">
            <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="currentColor">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href="https://x.com/w3api" class="sl-social-link" aria-label="X (Twitter)" target="_blank" rel="noopener noreferrer">
            <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.657l-5.207-6.807-5.966 6.807H2.882l7.432-8.499L1.085 2.25h6.82l4.713 6.231 5.579-6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <a href="https://github.com/w3api" class="sl-social-link" aria-label="GitHub" target="_blank" rel="noopener noreferrer">
            <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
          <a href="https://www.linkedin.com/in/victorcuervo/" class="sl-social-link" aria-label="LinkedIn" target="_blank" rel="noopener noreferrer">
            <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.475-2.236-1.986-2.236-1.081 0-1.722.722-2.004 1.418-.103.249-.129.597-.129.946v5.441h-3.554s.05-8.824 0-9.745h3.554v1.378c.429-.662 1.196-1.608 2.905-1.608 2.324 0 4.068 1.516 4.068 4.78v5.195zM5.337 8.855c-1.144 0-1.915-.758-1.915-1.71 0-.956.77-1.71 1.954-1.71 1.184 0 1.915.754 1.915 1.71 0 .952-.731 1.71-1.954 1.71zm1.649 11.597H3.694V9.407h3.292v10.845zM22.224 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.224 0z"/>
            </svg>
          </a>
        </div>

        <div class="sl-header-end">
          <!-- Language Switcher -->
          <LanguageSwitcher 
            currentLanguage={uiLanguage} 
            currentTechnology={currentTechnology}
            hasLanguagePrefix={hasLanguagePrefix}
          />
          
          <!-- Theme toggle -->
          <button id="theme-toggle" class="sl-icon-btn" aria-label="Cambiar tema">
            <svg class="sl-icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="4"/><line x1="12" y1="2" x2="12" y2="6"/>
              <line x1="12" y1="18" x2="12" y2="22"/><line x1="4.22" y1="4.22" x2="7.05" y2="7.05"/>
              <line x1="16.95" y1="16.95" x2="19.78" y2="19.78"/><line x1="2" y1="12" x2="6" y2="12"/>
              <line x1="18" y1="12" x2="22" y2="12"/><line x1="4.22" y1="19.78" x2="7.05" y2="16.95"/>
              <line x1="16.95" y1="7.05" x2="19.78" y2="4.22"/>
            </svg>
            <svg class="sl-icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
          </button>
        </div>
      </div>
    </header>

    <!-- PAGE FRAME -->
    <div class="sl-page-frame">

      <!-- SIDEBAR -->
      <SidebarNav items={sidebar} currentPath={currentPath} languageCode={uiLanguage} currentTechnology={currentTechnology} hasLanguagePrefix={hasLanguagePrefix} hasSidebar={hasSidebar} technologyFilter={technologyFilter} />

      <!-- MAIN CONTENT + TOC -->
      <div class:list={['sl-content-panel', { 'sl-no-sidebar': !hasSidebar }]}>

        <!-- MAIN -->
        <main id="main-content" class="sl-main">
          <div class="sl-content">
            <slot />
          </div>
        </main>

        <!-- TABLE OF CONTENTS -->
        {hasToc && tableOfContents.length > 0 && (
          <aside class="sl-toc" aria-label="Tabla de contenidos">
            <div class="sl-toc-inner">
              <h2 class="sl-toc-title">{t('onThisPage', uiLanguage)}</h2>
              <ul class="sl-toc-list">
                {tableOfContents.map((item) => (
                  <li class={`sl-toc-item sl-toc-depth-${item.depth}`}>
                    <a href={`#${item.slug}`} class="sl-toc-link">{t(item.text as any, uiLanguage)}</a>
                  </li>
                ))}
              </ul>
            </div>
          </aside>
        )}

      </div>
    </div>

    <!-- OVERLAY for mobile sidebar -->
    <div id="sidebar-overlay" class="sl-overlay" aria-hidden="true"></div>

    <style>
      /* ============================
         CSS CUSTOM PROPERTIES (Light)
         ============================ */
      :root {
        /* Colors */
        --sl-color-white: #ffffff;
        --sl-color-gray-1: #f6f6f7;
        --sl-color-gray-2: #e8e8ea;
        --sl-color-gray-3: #c2c2c4;
        --sl-color-gray-4: #8b8b8d;
        --sl-color-gray-5: #545456;
        --sl-color-gray-6: #353537;
        --sl-color-black: #18181b;

        --sl-color-accent-low: #d6e4ff;
        --sl-color-accent: #3b82f6;
        --sl-color-accent-high: #1e40af;

        /* Backgrounds */
        --sl-color-bg: var(--sl-color-white);
        --sl-color-bg-nav: var(--sl-color-gray-1);
        --sl-color-bg-sidebar: var(--sl-color-white);
        --sl-color-bg-inline-code: var(--sl-color-gray-2);
        --sl-color-bg-accent: var(--sl-color-accent-low);

        /* Text */
        --sl-color-text: var(--sl-color-gray-6);
        --sl-color-text-accent: var(--sl-color-accent-high);
        --sl-color-text-invert: var(--sl-color-white);
        --sl-color-hairline: var(--sl-color-gray-2);
        --sl-color-hairline-light: var(--sl-color-gray-2);
        --sl-color-hairline-shade: var(--sl-color-gray-3);
        --sl-color-accent-teal: #ff0000;        

        /* Badges */
        --sl-color-bg-badge-default: #e4e4e7;
        --sl-color-text-badge-default: var(--sl-color-gray-5);

        /* Layout */
        --sl-sidebar-width: 18rem;
        --sl-toc-width: 14rem;
        --sl-content-width: 65rem;
        --sl-content-pad-x: 2rem;
        --sl-header-height: 4rem;
        --sl-mobile-toc-height: 3rem;

        /* Typography */
        --sl-font: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        --sl-font-mono: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        --sl-text-xs: 0.75rem;
        --sl-text-sm: 0.875rem;
        --sl-text-base: 1rem;
        --sl-text-lg: 1.125rem;
        --sl-text-xl: 1.25rem;
        --sl-text-2xl: 1.5rem;
        --sl-text-3xl: 1.875rem;
        --sl-text-4xl: 2.25rem;
        --sl-text-5xl: 3rem;

        /* Shadows */
        --sl-shadow-sm: 0 1px 2px rgba(0,0,0,.06);
        --sl-shadow-md: 0 4px 6px rgba(0,0,0,.08);

        /* Border radius */
        --sl-border-radius: 0.375rem;
      }

      /* Dark mode */
      :root[data-theme="dark"],
      [data-theme="dark"] {
        --sl-color-bg: #17181c;
        --sl-color-bg-nav: #17181c;
        --sl-color-bg-sidebar: #1c1d22;
        --sl-color-bg-inline-code: #2a2b32;
        --sl-color-bg-accent: #1e2d4f;

        --sl-color-text: #c8c9ce;
        --sl-color-text-accent: #93c5fd;
        --sl-color-hairline: #2e2f36;
        --sl-color-hairline-light: #2e2f36;
        --sl-color-hairline-shade: #3a3b44;

        --sl-color-accent: #3b82f6;
        --sl-color-accent-low: #1e3a5f;
        --sl-color-accent-high: #93c5fd;

        --sl-color-bg-badge-default: #2e2f36;
        --sl-color-text-badge-default: #a1a1aa;
      }

      /* ============================
         RESET & BASE
         ============================ */
      *, *::before, *::after { box-sizing: border-box; }

      body {
        margin: 0;
        padding: 0;
        font-family: var(--sl-font);
        font-size: var(--sl-text-base);
        color: var(--sl-color-text);
        background-color: var(--sl-color-bg);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }

      a { color: inherit; text-decoration: none; }

      /* ============================
         HEADER
         ============================ */
      .sl-header {
        position: fixed;
        top: 0;
        inset-inline: 0;
        height: var(--sl-header-height);
        z-index: 10;
        background-color: var(--sl-color-bg-nav);
        border-bottom: 1px solid var(--sl-color-hairline);
        box-shadow: var(--sl-shadow-sm);
      }

      .sl-header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 100%;
        padding: 0 1rem;
        max-width: calc(var(--sl-sidebar-width) + var(--sl-content-width) + var(--sl-toc-width) + 4rem);
        margin: 0 auto;
        gap: 1rem;
      }

      .sl-header-start,
      .sl-header-end {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        height: var(--sl-header-height);
        flex-shrink: 0;
      }

      .sl-header-center {
        display: flex;
        align-items: center;
        justify-content: center;
        flex: 0 0 300px;
        padding: 0 1rem;
        min-width: 200px;
        height: var(--sl-header-height);
        overflow: visible;
      }

      @media (max-width: 50rem) {
        .sl-header-center {
          flex: 1;
          justify-content: flex-end;
          padding: 0 0.5rem;
          min-width: auto;
        }
      }

      /* Navigation Links */
      .sl-header-nav {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        height: var(--sl-header-height);
        flex-shrink: 0;
      }

      @media (max-width: 768px) {
        .sl-header-nav {
          display: none;
        }
      }

      .sl-nav-link {
        font-size: var(--sl-text-sm);
        color: var(--sl-color-text);
        text-decoration: none;
        font-weight: 500;
        transition: color 0.15s;
      }
      .sl-nav-link:hover { color: var(--sl-color-accent); }

      /* Social Icons Placeholder */
      .sl-header-social {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        height: var(--sl-header-height);
        flex-shrink: 0;
        min-width: 60px;
      }

      @media (max-width: 1024px) {
        .sl-header-social {
          display: none;
        }
      }

      .sl-social-link {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 1.25rem;
        height: 1.25rem;
        color: var(--sl-color-text);
        transition: color 0.15s, transform 0.15s;
        border-radius: var(--sl-border-radius);
      }

      .sl-social-link:hover {
        color: var(--sl-color-accent);
        transform: scale(1.1);
      }

      .sl-social-link svg {
        width: 100%;
        height: 100%;
      }

      .sl-site-title {
        display: flex;
        align-items: center;
        gap: 1rem;
        font-family: 'Geist', system-ui, -apple-system, sans-serif;
        font-weight: 700;
        font-size: var(--sl-text-lg);
        letter-spacing: -0.02em;
        color: var(--sl-color-text);
        white-space: nowrap;
        text-decoration: none;
        height: var(--sl-header-height);
      }

      @media (min-width: 50rem) {
        .sl-site-title {
          font-size: var(--sl-text-2xl);
        }
      }
      .sl-site-title:hover { color: var(--sl-color-accent); }

      .sl-logo {
        height: 2.5rem;
        width: auto;
      }

      @media (min-width: 50rem) {
        .sl-logo {
          height: 3.5rem;
        }
      }

      /* ============================
         ICON BUTTONS
         ============================ */
      .sl-icon-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 2rem;
        height: 2rem;
        border: 1px solid var(--sl-color-hairline);
        border-radius: var(--sl-border-radius);
        background: transparent;
        color: var(--sl-color-text);
        cursor: pointer;
        transition: background 0.15s, color 0.15s;
      }
      .sl-icon-btn:hover { background: var(--sl-color-bg-sidebar); }

      .sl-icon-moon { display: none; }
      [data-theme="dark"] .sl-icon-sun { display: none; }
      [data-theme="dark"] .sl-icon-moon { display: block; }

      /* ============================
         MOBILE TOGGLE
         ============================ */
      .sl-mobile-toggle {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 2rem;
        height: 2rem;
        background: transparent;
        border: none;
        color: var(--sl-color-text);
        cursor: pointer;
        border-radius: var(--sl-border-radius);
      }
      .sl-mobile-toggle:hover { background: var(--sl-color-bg-sidebar); }

      @media (min-width: 50rem) {
        .sl-mobile-toggle { display: none; }
      }

      /* ============================
         PAGE FRAME
         ============================ */
      .sl-page-frame {
        display: flex;
        padding-top: var(--sl-header-height);
        min-height: 100dvh;
      }

      /* ============================
         CONTENT PANEL
         ============================ */
      .sl-content-panel {
        display: flex;
        flex: 1;
        min-width: 0;
        margin-inline-start: 0;
      }

      @media (min-width: 50rem) {
        .sl-content-panel {
          margin-inline-start: var(--sl-sidebar-width);
        }
        .sl-content-panel.sl-no-sidebar {
          margin-inline-start: 0;
          justify-content: center;
        }
      }

      .sl-content-panel.sl-no-sidebar {
        margin-inline-start: 0;
        justify-content: center;
      }

      /* ============================
         MAIN
         ============================ */
      .sl-main {
        flex: 1;
        min-width: 0;
        display: flex;
        flex-direction: column;
        width: 100%;
      }

      .sl-content-panel.sl-no-sidebar .sl-main {
        max-width: var(--sl-content-width);
        margin: 0 auto;
      }

      .sl-content {
        flex: 1;
        max-width: var(--sl-content-width);
        width: 100%;
        padding: 1rem var(--sl-content-pad-x) 4rem;
        margin: 0 auto;
      }

      @media (min-width: 72rem) {
        .sl-content {
          margin-inline-start: 0;
          padding-inline-start: 2rem;
          padding-inline-end: 1.5rem;
        }
      }

      /* ============================
         PROSE STYLES
         ============================ */
      .sl-content :is(h1, h2, h3, h4, h5, h6) {
        font-weight: 700;
        line-height: 1.3;
        color: var(--sl-color-black);
      }
      [data-theme="dark"] .sl-content :is(h1, h2, h3, h4, h5, h6) {
        color: #f4f4f5;
      }
      .sl-content h1 {
        font-size: var(--sl-text-2xl);
      }

      @media (min-width: 50rem) {
        .sl-content h1 {
          font-size: var(--sl-text-4xl);
        }
      }
      .sl-content h2 { font-size: var(--sl-text-2xl); margin: 2rem 0 0.75rem; padding-top: 1rem; border-top: 1px solid var(--sl-color-hairline); }
      .sl-content h3 { font-size: var(--sl-text-xl);  margin: 1.5rem 0 0.5rem; }
      .sl-content h4 { font-size: var(--sl-text-lg);  margin: 1.25rem 0 0.5rem; }
      .sl-content p  { margin: 0.75rem 0; }
      .sl-content :is(a)  { color: var(--sl-color-text-accent); text-decoration: underline; text-underline-offset: 3px; }
      .sl-content :is(a):visited { color: var(--sl-color-text-accent); }
      .sl-content :is(a):hover { color: var(--sl-color-accent-high); }

      .sl-content code {
        font-family: var(--sl-font-mono);
        font-size: 0.875em;
        background: var(--sl-color-bg-inline-code);
        padding: 0.15em 0.35em;
        border-radius: 4px;
      }
      .sl-content pre {
        background: var(--sl-color-bg-inline-code);
        border: 1px solid var(--sl-color-hairline);
        border-radius: var(--sl-border-radius);
        padding: 1rem 1.25rem;
        overflow-x: auto;
        font-family: var(--sl-font-mono);
        font-size: var(--sl-text-sm);
        line-height: 1.7;
      }
      .sl-content pre code { background: none; padding: 0; }

      .sl-content blockquote {
        border-inline-start: 3px solid var(--sl-color-accent);
        margin: 1rem 0;
        padding: 0.5rem 1rem;
        background: var(--sl-color-bg-accent);
        border-radius: 0 var(--sl-border-radius) var(--sl-border-radius) 0;
        color: var(--sl-color-gray-5);
      }

      .sl-content table {
        width: 100%;
        border-collapse: collapse;
        font-size: var(--sl-text-sm);
      }
      .sl-content th, .sl-content td {
        padding: 0.5rem 0.75rem;
        border: 1px solid var(--sl-color-hairline);
        text-align: left;
      }
      .sl-content th {
        background: var(--sl-color-bg-sidebar);
        font-weight: 600;
      }

      .sl-content ul, .sl-content ol {
        padding-inline-start: 1.5rem;
        margin: 0.75rem 0;
      }
      .sl-content li { margin: 0.25rem 0; }

      .sl-content hr {
        border: none;
        border-top: 1px solid var(--sl-color-hairline);
        margin: 2rem 0;
      }

      .sl-content img {
        max-width: 100%;
        border-radius: var(--sl-border-radius);
      }

      /* ============================
         TABLE OF CONTENTS
         ============================ */
      .sl-toc {
        display: none;
        width: var(--sl-toc-width);
        flex-shrink: 0;
      }

      @media (min-width: 72rem) {
        .sl-toc {
          display: block;
        }
      }

      .sl-toc-inner {
        position: sticky;
        top: calc(var(--sl-header-height) + 1.5rem);
        max-height: calc(100dvh - var(--sl-header-height) - 3rem);
        overflow-y: auto;
        padding: 0 1rem 2rem;
        scrollbar-width: thin;
        scrollbar-color: var(--sl-color-gray-3) transparent;
      }

      .sl-toc-title {
        font-size: var(--sl-text-xs);
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--sl-color-gray-4);
        margin: 0 0 0.5rem;
        padding: 0;
      }

      .sl-toc-list {
        list-style: none;
        margin: 0;
        padding: 0;
        border-inline-start: 1px solid var(--sl-color-hairline);
      }

      .sl-toc-item { padding: 0; }

      .sl-toc-link {
        display: block;
        padding: 0.2rem 0.75rem;
        font-size: var(--sl-text-sm);
        color: var(--sl-color-gray-4);
        text-decoration: none;
        transition: color 0.15s;
        border-inline-start: 1px solid transparent;
        margin-inline-start: -1px;
      }
      .sl-toc-link:hover { color: var(--sl-color-text); border-color: var(--sl-color-gray-3); }
      .sl-toc-link.active { color: var(--sl-color-accent); border-color: var(--sl-color-accent); }

      .sl-toc-depth-3 .sl-toc-link { padding-inline-start: 1.5rem; }
      .sl-toc-depth-4 .sl-toc-link { padding-inline-start: 2.25rem; }

      /* ============================
         OVERLAY
         ============================ */
      .sl-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.5);
        z-index: 7;
        opacity: 0;
        transition: opacity 0.25s;
      }

      .sl-overlay[data-open="true"] {
        display: block;
        opacity: 1;
      }

      /* ============================
         DOCUMENT PAGE STYLES (General)
         ============================ */
      :global(.header-divider) {
        border: none;
        border-top: 1px solid var(--sl-color-hairline);
        margin: 1rem 0;
      }

      :global(.sl-content-header h1) {
        margin: 0;
      }

      :global(#metadata) {
        margin: 1.5rem 0;
      }

      :global(.metadata-badges) {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        align-items: center;
      }

      :global(.metadata-badges .sl-badge) {
        display: inline-flex;
        align-items: center;
        padding: 0.35rem 0.75rem;
        font-size: 0.875rem;
        font-weight: 600;
        border-radius: 0.375rem;
        white-space: nowrap;
      }

      :global(.sl-badge-tip) {
        background-color: var(--sl-color-accent-low);
        color: var(--sl-color-accent);
      }

      :global(.sl-badge-success) {
        background-color: #dcfce7;
        color: #166534;
      }

      :global(.sl-badge-caution) {
        background-color: #fef3c7;
        color: #b45309;
      }

      /* Dark mode badge styles */
      :global([data-theme="dark"] .sl-badge-success) {
        background-color: #064e3b;
        color: #86efac;
      }

      :global([data-theme="dark"] .sl-badge-caution) {
        background-color: #78350f;
        color: #fcd34d;
      }

      :global([data-theme="dark"] .sl-badge-tip) {
        background-color: #1e3a5f;
        color: #93c5fd;
      }

      :global(.members-category h3) {
        margin: 1.5rem 0 0.75rem 0;
        font-size: 1rem;
        font-weight: 600;
        color: var(--sl-color-text);
        border-bottom: 1px solid var(--sl-color-hairline);
        padding-bottom: 0.5rem;
      }

      :global(.members-category ul) {
        list-style: none;
        padding: 0;
        margin: 0 0 1rem 0;
      }

      :global(.members-category li) {
        padding: 0.1rem 0;
      }

      :global(.members-category a) {
        color: var(--sl-color-accent);
        text-decoration: none;
        transition: color 0.15s;
      }

      :global(.members-category a:hover) {
        color: var(--sl-color-accent-high);
        text-decoration: underline;
      }

      /* ============================
         INLINE CODE
         ============================ */
      :global(code) {
        background-color: var(--sl-color-bg-inline-code);
        color: var(--sl-color-text);
        padding: 0.2rem 0.4rem;
        border-radius: 0.25rem;
        font-size: 0.9em;
        font-family: var(--sl-font-mono);
      }
    </style>

    <script>
      // ——————————————————————————————
      // THEME TOGGLE
      // ——————————————————————————————
      const html = document.documentElement;
      const themeToggle = document.getElementById('theme-toggle');

      // Initialize theme from localStorage or system preference
      const stored = localStorage.getItem('sl-theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const initial = stored ?? (prefersDark ? 'dark' : 'light');
      html.dataset.theme = initial;

      themeToggle?.addEventListener('click', () => {
        const next = html.dataset.theme === 'dark' ? 'light' : 'dark';
        html.dataset.theme = next;
        localStorage.setItem('sl-theme', next);
      });

      // ——————————————————————————————
      // MOBILE SIDEBAR TOGGLE
      // ——————————————————————————————
      const menuToggle = document.getElementById('mobile-menu-toggle');
      const sidebar = document.getElementById('sidebar');
      const overlay = document.getElementById('sidebar-overlay');

      function openSidebar() {
        sidebar?.setAttribute('data-open', 'true');
        overlay?.setAttribute('data-open', 'true');
        menuToggle?.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
      }

      function closeSidebar() {
        sidebar?.removeAttribute('data-open');
        overlay?.removeAttribute('data-open');
        menuToggle?.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      }

      menuToggle?.addEventListener('click', () => {
        const isOpen = sidebar?.dataset.open === 'true';
        isOpen ? closeSidebar() : openSidebar();
      });

      overlay?.addEventListener('click', closeSidebar);

      // ——————————————————————————————
      // TABLE OF CONTENTS: Active link on scroll
      // ——————————————————————————————
      const tocLinks = document.querySelectorAll('.sl-toc-link');
      const headings = document.querySelectorAll('.sl-content h2, .sl-content h3, .sl-content h4');

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              tocLinks.forEach((link) => link.classList.remove('active'));
              const active = document.querySelector(`.sl-toc-link[href="#${entry.target.id}"]`);
              active?.classList.add('active');
            }
          });
        },
        { rootMargin: '-64px 0px -80% 0px' }
      );

      headings.forEach((h) => observer.observe(h));
    </script>
  </body>
</html>
