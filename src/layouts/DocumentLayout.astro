---
import StarlightLayout from './StarlightLayout.astro';
import { Code } from "astro-expressive-code/components";
import { Breadcrumbs } from "astro-breadcrumbs";
import "astro-breadcrumbs/breadcrumbs.css";
import DocumentAsidePanel from '../components/DocumentAsidePanel.astro';
import { marked } from 'marked';
import { t } from '../i18n';
import type { Language } from '../i18n';

interface SidebarItem {
  label: string;
  link?: string;
  items?: SidebarItem[];
  badge?: { text: string; variant?: 'default' | 'note' | 'tip' | 'caution' | 'danger' | 'success' };
  collapsed?: boolean;
}

interface TocItem {
  depth: number;
  text: string;
  slug: string;
}

interface Props {
  doc: any;
  slug: string;
  sidebar: SidebarItem[];
  technology: string;
  technologyName: string;
  uiLanguage: Language;
  technologyFilter: string;
  technologyCode: string;
  isPackagePage: boolean;
  tableOfContents: TocItem[];
  hasLanguagePrefix?: boolean;
}

const {
  doc,
  slug,
  sidebar,
  technology,
  technologyName,
  uiLanguage,
  technologyFilter,
  technologyCode,
  isPackagePage,
  tableOfContents,
  hasLanguagePrefix = true,
} = Astro.props;

const languageIcons: Record<string, string> = {
  css: 'devicon-css3-plain',
  html: 'devicon-html5-plain',
  java: 'devicon-java-plain',
  javascript: 'devicon-javascript-plain',
  jquery: 'devicon-jquery-plain',
  python: 'devicon-python-plain',
  svg: 'devicon-html5-plain',
  xml: 'devicon-xml-plain',
};

const buildUrl = (slug: string) => {
  if (hasLanguagePrefix) {
    return `/${uiLanguage}/${technology}/${slug}/`;
  } else {
    return `/${technology}/${slug}/`;
  }
};

const languageIcon = languageIcons[technology] || '';
const title = `${doc.parent ? `${doc.parent}.` : ''}${doc.name} ${t('in', uiLanguage)} ${technologyName}`;

// Generar breadcrumb trail sin el idioma
const buildBreadcrumbTrail = () => {
  const breadcrumbs: Array<{ label: string; url: string }> = [
    { label: t('home', uiLanguage), url: '/' },
    { label: technology.toUpperCase(), url: buildUrl(technology) }
  ];

  const slugParts = slug.split('/').filter(Boolean);
  let currentPath = `${technology}`;
  
  for (let i = 0; i < slugParts.length; i++) {
    currentPath += `/${slugParts[i]}`;
    breadcrumbs.push({
      label: slugParts[i],
      url: buildUrl(currentPath)
    });
  }
  
  return breadcrumbs;
};

const breadcrumbTrail = buildBreadcrumbTrail();
---

<StarlightLayout
  title={title}
  description={`${technologyName} ${doc.type} ${doc.name}`}
  siteTitle="W3Api"
  sidebar={sidebar}
  tableOfContents={tableOfContents}
  uiLanguage={uiLanguage}
  logoSrc='/logo.webp'
  technologyFilter={technologyFilter}
>
  <main>
    <article>
      <header class="sl-content-header">
        <div class="header-container">
          <h1>{title}</h1>
        </div>
        {languageIcon && (
          <i class={`devicon ${languageIcon} language-logo`}></i>
        )}
        <nav class="sl-breadcrumb-nav">
          <Breadcrumbs excludeCurrentPage customizeLinks={breadcrumbTrail} indexText={t('inicio', uiLanguage)} separatorAriaHidden={false}>
            <svg
              slot="separator"
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
            <svg
              slot="index"
              aria-label="Página Principal"
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
              <polyline points="9 22 9 12 15 12 15 22"></polyline>
            </svg>
          </Breadcrumbs>
        </nav>
      </header>

      <hr class="header-divider" />

      <section id="metadata">
        <div class="metadata-badges">
          <span class="sl-badge sl-badge-tip">{doc.type}</span>

          {doc.metadata?.added_version && (
            <span class="sl-badge sl-badge-success">
              {t('addedIn', uiLanguage)} {doc.metadata.added_version}
            </span>
          )}

          {doc.metadata?.status === "deprecated" && doc.metadata?.deprecated_version && doc.metadata.deprecated_version !== "unknown" && (
            <span class="sl-badge sl-badge-caution">
              {t('deprecatedIn', uiLanguage)} {doc.metadata.deprecated_version}
            </span>
          )}

          {doc.metadata?.status === "deprecated" && (!doc.metadata?.deprecated_version || doc.metadata.deprecated_version === "unknown") && (
            <span class="sl-badge sl-badge-caution">
              {t('deprecated', uiLanguage)}
            </span>
          )}

          {doc.metadata?.status === "experimental" && (
            <span class="sl-badge sl-badge-experimental">
              Experimental
            </span>
          )}
        </div>
      </section>

      <section id="description">
        <h2>{t('description', uiLanguage)}</h2>
        <div set:html={marked(
          typeof doc.description === 'object' 
            ? (doc.description[uiLanguage] || doc.description.en || t('noDescription', uiLanguage))
            : (doc.description || t('noDescription', uiLanguage))
        )} />
      </section>

      {isPackagePage && doc.membersByType && Object.keys(doc.membersByType).length > 0 && (
        <section id="members">
          <h2>{t('members', uiLanguage)}</h2>
          {Object.entries(doc.membersByType).map(([type, members]: any) => {
            const typeLabel = type.charAt(0).toUpperCase() + type.slice(1)
            return (
              <div class="members-category">
                <h3>{typeLabel}</h3>
                <ul>
                  {(members as any[]).map((member: any) => (
                    <li>
                      <a href={buildUrl(member.slug)}>
                        {member.name || member.slug.split('/')[1]}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )
          })}
        </section>
      )}

      {!isPackagePage && doc.signatures && doc.signatures.length > 0 && (
        <section id="sintaxis">
          <h2>{t('syntax', uiLanguage)}</h2>
          <Code code={doc.signatures.join('\n')} lang={technologyCode} />
        </section>
      )}

      {!isPackagePage && doc.parameters && doc.parameters.length > 0 && (
        <section id="parameters">
          <h2>{t('parameters', uiLanguage)}</h2>
          <ul>
            {doc.parameters.map((param: any) => (
              <li>
                <strong>{param.type} {param.name}</strong> - {
                  typeof param.description === 'object' 
                    ? (param.description[uiLanguage] || param.description.en || '')
                    : (param.description || '')
                }
              </li>
            ))}
          </ul>
        </section>
      )}

      {!isPackagePage && doc.constructors && doc.constructors.length > 0 && (
        <section id="constructors">
          <h2>{t('constructors', uiLanguage)}</h2>
          <div class="members-category">
            <ul>
              {doc.constructors.map((constructor: string) => (
                <li>
                  <a href={buildUrl(`${slug}/${constructor}`)}>
                    {constructor}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </section>
      )}

      {!isPackagePage && doc.methods && doc.methods.length > 0 && (
        <section id="methods">
          <h2>{t('methods', uiLanguage)}</h2>
          <div class="members-category">
            <ul>
              {doc.methods.map((method: string) => (
                <li>
                  <a href={buildUrl(`${slug}/${method}`)}>
                    {method}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </section>
      )}

      {!isPackagePage && doc.attributes && doc.attributes.length > 0 && (
        <section id="attributes">
          <h2>{t('attributes', uiLanguage)}</h2>
          <div class="members-category">
            <ul>
              {doc.attributes.map((attribute: string) => (
                <li>
                  <a href={buildUrl(`${slug}/${attribute}`)}>
                    {attribute}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </section>
      )}

      {!isPackagePage && doc.exceptions && doc.exceptions.length > 0 && (
        <section id="exceptions">
          <h2>{t('exceptions', uiLanguage)}</h2>
          <div class="members-category">
            <ul>
              {doc.exceptions.map((exception: any) => (
                <li>
                  <a href={buildUrl(`${exception.package}/${exception.name}`)}>
                    {exception.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </section>
      )}

      {!isPackagePage && doc.example && doc.example.length > 0 && (
        <section id="example">
          <h2>{t('example', uiLanguage)}</h2>
          <Code code={doc.example} lang={technologyCode} />
        </section>
      )}
    </article>

    <DocumentAsidePanel {doc} {isPackagePage} {technology} {technologyName} {uiLanguage} {hasLanguagePrefix} />
  </main>
</StarlightLayout>

<style>
  .header-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .header-container h1 {
    margin: 0 0 0.5rem 0;
    flex: 1;
    font-size: 1.3rem;
    line-height: 1.2;
    word-break: break-word;
    overflow-wrap: break-word;
  }

  @media (min-width: 50rem) {
    .header-container h1 {
      font-size: 1.8rem;      
      line-height: 1.3;
    }
  }

  .sl-content-header {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
    padding-top: 1rem;
    align-items: start;
  }

  .sl-content-header > .header-container {
    grid-column: 1;
    grid-row: 1;
  }

  .sl-content-header > .language-logo {
    grid-column: 2;
    grid-row: 1 / 3;
    align-self: center;
  }

  .sl-content-header > .sl-breadcrumb-nav {
    grid-column: 1;
    grid-row: 2;
  }

  .sl-breadcrumb-nav {
    width: 100%;
  }

  .language-logo {
    font-size: 2.5rem;
    opacity: 0.8;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }

  @media (min-width: 50rem) {
    .language-logo {
      font-size: 4rem;
    }
  }

  .sl-badge-experimental {
    background: linear-gradient(135deg, #a855f7 0%, #7c3aed 100%);
    color: white;
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
  }

  .sl-badge-experimental svg {
    width: 1em;
    height: 1em;
    flex-shrink: 0;
  }

  [data-theme="dark"] .sl-badge-experimental {
    background: linear-gradient(135deg, #c084fc 0%, #a855f7 100%);
  }
</style>
