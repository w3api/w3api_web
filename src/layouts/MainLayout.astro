---
import Header from '../components/Header.astro'
import Sidebar from '../components/Sidebar.astro'

interface Props {
  title: string
  description?: string
  headings?: Array<{level: number; title: string; id: string}>
}

const { title, description, headings = [] } = Astro.props
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		{description && <meta name="description" content={description} />}
		<title>{title} - W3Api</title>
	</head>
	<body>
		<Header />
		
		<div class="main-container">
			<Sidebar position="left" />
			
			<main class="main-content">
				<slot />
			</main>
			
			<Sidebar position="right" headings={headings} />
		</div>
	</body>
</html>

<style>
	:global(html, body) {
		margin: 0;
		padding: 0;
		font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
		color: #000;
		background: #fff;
	}

	:global(html) {
		scroll-behavior: smooth;
	}

	.main-container {
		display: grid;
		grid-template-columns: 280px 1fr 280px;
		min-height: calc(100vh - 80px);
		max-width: 1400px;
		margin: 0 auto;
		gap: 0;
	}

	.main-content {
		padding: 2rem;
		background: #fff;
		overflow-y: auto;
	}

	:global(.main-content h1) {
		margin-top: 0;
		margin-bottom: 1rem;
		color: #317ACF;
		border-bottom: 2px solid #317ACF;
		padding-bottom: 0.5rem;
	}

	:global(.main-content h2) {
		margin-top: 2rem;
		margin-bottom: 1rem;
		color: #317ACF;
		border-bottom: 1px solid #333;
		padding-bottom: 0.5rem;
		scroll-margin-top: 90px;
	}

	:global(.main-content h3) {
		margin-top: 1.5rem;
		margin-bottom: 0.75rem;
		color: #000;
	}

	:global(.main-content p) {
		line-height: 1.6;
		margin-bottom: 1rem;
	}

	:global(.main-content section) {
		margin-bottom: 2rem;
	}

	:global(.main-content a) {
		color: #317ACF;
		text-decoration: none;
		border-bottom: 1px solid transparent;
		transition: border-color 0.2s;
	}

	:global(.main-content a:hover) {
		border-bottom-color: #317ACF;
	}

	@media (max-width: 1024px) {
		.main-container {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 768px) {
		.main-container {
			grid-template-columns: 1fr;
		}

		.main-content {
			padding: 1rem;
		}
	}
</style>
